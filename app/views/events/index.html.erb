<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My Events</h1>
    <%= link_to "Add New Event", new_event_path, class: "btn btn-outline-primary border-radius-5" %>
  </div>


  <% if @events.any? %>
    <div class="row g-4">
      <% @events.each do |event| %>
        <div class="col-md-4">
           <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body">
              <div  class="d-flex justify-content-left gap-2">
                <h5 class="card-title text-success">
                  <%= event.title %>
                </h5>
                <%# Edit event  %>
                  <%= link_to edit_event_path(event), class:"text-dark" do %>
                  <i class="bi bi-pencil-square"></i>
                  <% end %>
                <%# Delet event  %>
                  <%=link_to event_path(event), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },  class:"text-dark" do %>
                  <i class="bi bi-trash"></i>
                  <% end %>
              </div>
              <p class="text-muted mb-1"><i class="fa-regular fa-calendar-days" me-1></i> <%= event.start_time.strftime("%B %d %Y") %></p>
              <p class="text-muted mb-1"><i class="fa-regular fa-clock" me-1></i> <%= event.start_time.strftime("%I: %M %p") %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">No events saved yet!</p>
  <% end %>
</div>
