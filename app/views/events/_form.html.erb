<div class="container mt-4">
  <div class="row justify-content-left ms-2">
    <div class="col-md-12">
      <%= simple_form_for(@event) do |f| %>

        <div class="form-inputs fw-bold">
        <%# u %>
          <%= f.input :title %>
        <%# select_date %>
          <%= f.input :start_time, as: :datetime,  html5: true, label:"Select Date and Time" %>
        </div>

         <div class="d-flex gap-3 mb-4 mt-2">
          <%= f.submit class: "btn btn-primary border-radius-5 fs-5" %>
          <%= link_to "Cancel", events_path, class: "btn btn-outline-primary border-radius-5 fs-5" %>
        </div>
        <% end %>
    </div>
  </div>
</div>
