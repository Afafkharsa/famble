<div class="container mt-4">
  <div>
    <% if @task_templates.any? %>
      <h2 class="mt-3">
        My family task templates <%= link_to new_task_template_path do %>
            <i class="fa-solid fa-plus text-body-secondary fs-4"
            style= "text-decoration: none; cursor: pointer; color: inherit;" ></i>
        <% end %>
      </h2>
      <div class="row g-4">
        <% @task_templates.each do |task_template| %>
          <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 bg-white">
              <div class="card-body">
                <h5 class="card-title text-secondary">
                  <%= task_template.name %>
                </h5>

                <div class = "d-flex mb-0 mt-3 rounded-2 bg-secondary-subtle justify-content-between">

                  <div class="badge text-secondary py-2">
                      <i class="fa-solid fa-award"></i>
                      <%= task_template.task_points > 0 ? "#{task_template.task_points} points" : "#{task_template.task_points} point"  %>
                  </div>
                </div>

                <h5 class="h5 fw-bold text-secondary mt-4">Description</h5>
                <div class="mt-2">
                  <%= task_template.description? ? task_template.description : "No description" %>
                </div>

                <div  class="d-flex justify-content-between mt-3">
                  <%= link_to "View task_template", task_template_path(task_template),
                    class: "btn btn-outline-secondary btn-sm rounded-pill" %>
                  <%= link_to "Delete task", task_template_path(task_template),
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                    class: "btn btn-outline-danger btn-sm rounded-pill" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
