<%= simple_form_for(task_template) do |f| %>

  <%= f.input :name, placeholder: "Template name", label: "Name",
      wrapper_html: { class: "mb-3" } %>

  <%= f.input :description, placeholder: "Template description", label: "Description",
      wrapper_html: { class: "mb-3" } %>

  <%= f.input :task_points, collection: 1..10, label: "Reward points",
      selected: task_template.task_points || 1, prompt: "Points",
      wrapper_html: { class: "mb-3" } %>

  <%= f.input :days,
      collection: ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
      as: :check_boxes,
      input_html: { multiple: true },
      label: "Repeat on days",
      wrapper_html: { class: "mb-3" } %>

  <%= f.input :montly_frequency, collection: 0..12,
      selected: task_template.montly_frequency || 0,
      label: "Monthly frequency",
      wrapper_html: { class: "mb-4" } %>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "btn btn-primary rounded-4" %>
    <%= link_to "Cancel", task_templates_path, class: "btn btn-outline-secondary rounded-4" %>
  </div>

<% end %>
