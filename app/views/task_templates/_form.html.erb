<%= simple_form_for(task_template) do |f| %>
  <div class="d-flex align-items-center">
    <div class="pe-2 text-secondary fw-bold">Done?</div>
    <div class="pe-2 ps-4 text-secondary fw-bold">Rewards point</div>
      <%= f.input_field :task_points, label: false, collection: 1..10, selected: 1 , input_html: { class: 'text-secondary' } %>
    <div class="pe-2 ps-4 text-secondary fw-bold">Family member</div>
  </div>
  <div class="mt-3">
    <div class="pe-2 text-secondary fw-bold mb-2">Task parameters</div>
    <%= f.input :name, placeholder: "Task template name", label: false , input_html: { class: 'text-secondary' }%>
    <%= f.input :description, placeholder: "Task template description",
    label: false, input_html: { class: 'text-secondary' } %>

  </div>
  <div class="d-flex">
    <div class="pe-2 col-6">
      <%= f.input :days,
        collection: ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
        as: :check_boxes,
        input_html: { multiple: true},
        label: "If repeating, on which days does the task occur?"%>
    </div>
    <div class="ps-2 col-6">
      <%= f.input :montly_frequency, collection: 0..12, selected: 0 %>
    </div>
  </div>
  <div  class="d-flex">
  </div>
  <%= f.submit class: "btn btn-primary" %>
<% end %>
