<%= form_with(model: reward, class: "mt-3") do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", placeholder: "e.g. Ice cream trip", data: { reward_template_target: "name" } %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3,
        placeholder: "Describe the reward..." %>
  </div>

  <div class="mb-3">
    <%= f.label :reward_points, "Points required", class: "form-label" %>
    <%= f.number_field :reward_points, class: "form-control", min: 0, data: { reward_template_target: "rewardPoints" } %>
  </div>

  <%= f.hidden_field :reward_template_id, data: { reward_template_target: "templateId" } %>

  <div class="mb-3">
    <%= f.label :icon, "Icon", class: "form-label" %>
    <div class="icon-picker">
      <% Reward::ICON_OPTIONS.each do |slug| %>
        <label class="icon-picker__option">
          <%= f.radio_button :icon, slug, class: "icon-picker__radio" %>
          <span class="icon-picker__tile">
            <%= lucide_icon slug, class: "icon-picker__svg" %>
          </span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :photo, "Photo (optional)", class: "form-label" %>
    <img src="" class="d-block mb-2 rounded" style="display: none; max-height: 150px; object-fit: cover;" data-reward-template-target="photoPreview">
    <%= f.file_field :photo, class: "form-control", accept: "image/*" %>
  </div>

  <div class="mb-3">
    <%= f.label :user_id, "Assign to", class: "form-label" %>
    <%= f.collection_select :user_id, family_members, :id, :email,
        { prompt: "Select a family member" }, { class: "form-select" } %>
  </div>

  <%= f.submit class: "btn btn-primary" %>
<% end %>
