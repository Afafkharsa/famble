<%= form_with(model: reward) do |f| %>
  <div class="mb-3">
    <%= f.label :name, "Name", class: "form-label" %>
    <%= f.text_field :name, class: "form-control",
          placeholder: "e.g. Ice cream trip",
          data: { reward_template_target: "name" } %>
  </div>

  <div class="mb-3">
    <%= f.label :icon, "Icon", class: "form-label" %>
    <div class="reward-icon-picker" data-reward-template-target="iconGrid">
      <% %w[gift star-fill trophy-fill controller film book music-note-beamed bicycle palette bag heart-fill sun lightning-fill award emoji-smile camera headphones cup-hot balloon-heart people-fill].each do |icon| %>
        <button type="button" class="icon-option <%= reward.icon == icon ? 'icon-option--active' : '' %>"
                data-action="click->reward-template#selectIcon"
                data-icon="<%= icon %>">
          <i class="bi bi-<%= icon %>"></i>
        </button>
      <% end %>
    </div>
    <%= f.hidden_field :icon, data: { reward_template_target: "iconInput" } %>
  </div>

  <div class="mb-3">
    <%= f.label :description, "Description", class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3,
          placeholder: "Describe the reward..." %>
  </div>

  <div class="mb-3">
    <%= f.label :reward_points, "Points required", class: "form-label" %>
    <%= f.number_field :reward_points, class: "form-control", min: 0,
          data: { reward_template_target: "rewardPoints" } %>
  </div>

  <%= f.hidden_field :reward_template_id, data: { reward_template_target: "templateId" } %>

  <div class="mb-3">
    <%= f.label :photo, "Photo", class: "form-label" %>
    <span class="text-muted small ms-1">(optional)</span>
    <img src="" class="d-block mb-2 rounded" style="display: none;"
         data-reward-template-target="photoPreview">
    <%= f.file_field :photo, class: "form-control", accept: "image/*" %>
  </div>

  <div class="mb-4">
    <%= f.label :user_id, "Assign to", class: "form-label" %>
    <%= f.collection_select :user_id, family_members, :id, :display_name,
          { prompt: "Select a family member" },
          { class: "form-select" } %>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "btn btn-primary rounded-4" %>
    <%= link_to "Cancel", rewards_path, class: "btn btn-outline-secondary rounded-4" %>
  </div>
<% end %>
