<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0 d-flex align-items-center gap-4">
      Family Rewards
      <%= link_to new_reward_path, class: "text-decoration-none text-secondary" do %>
        <i class="bi bi-plus-circle fs-4"></i>
      <% end %>
      <%= link_to  reward_templates_path, class: "text-decoration-none text-secondary"  do %>
        <i class="fa-regular fa-rectangle-list fs-4"></i>
      <% end %>
    </h1>
  </div>

  <div class="d-flex flex-column">
    <% current_user.family.users.each do |member| %>

      <div class="col-12 mb-4">
        <div class="d-flex align-items-center mb-3 flex-wrap">
          <% if member.photo.attached? %>
            <%= image_tag member.photo, class: "rounded-circle me-2", style: "width: 48px; height: 48px; object-fit: cover;" %>
          <% else %>
            <i class="bi bi-person-circle fs-2 me-2 text-secondary"></i>
          <% end %>
          <h4 class="mb-0 me-2"><%= member.name || member.email %></h4>
          <span class="badge bg-success fs-6">
            <%= member.available_points %> pts available
          </span>
          <span class="badge bg-primary ms-2">
            <%= member.earned_points %> earned
          </span>
          <span class="badge bg-danger ms-2">
            <%= member.spent_points %> spent
          </span>
        </div>
        <div class="container text-center">
          <div class="row">
            <% member_rewards = @rewards.select { |r| r.user_id == member.id } %>
            <% if member_rewards.any? %>
              <% member_rewards.each do |reward| %>
                <div class="col-md-4 p-1 mb-3 <%= 'border-success' if reward.redeemed? %>"
                    style="height: 180px;">
                <%= render "reward", reward: reward%>
                </div>
              <% end %>
            <% else %>
              <p class="text-muted">No rewards yet for this member.</p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
