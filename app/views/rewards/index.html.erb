<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Family Rewards</h1>
    <div>
      <%= link_to "Add Reward", new_reward_path, class: "btn btn-primary me-2" %>
      <%= link_to "Reward Library", reward_templates_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>

  <div class="row">
    <% current_user.family.users.each do |member| %>
      <div class="col-12 col-md-6 col-lg-4 mb-4 d-flex flex-column">
        <div class="d-flex align-items-center mb-3 flex-wrap">
          <% if member.photo.attached? %>
            <%= image_tag member.photo, class: "rounded-circle me-2", style: "width: 48px; height: 48px; object-fit: cover;" %>
          <% else %>
            <i class="bi bi-person-circle fs-2 me-2 text-secondary"></i>
          <% end %>
          <h4 class="mb-0 me-2"><%= member.name || member.email %></h4>
          <span class="badge bg-success fs-6">
            <%= member.available_points %> pts available
          </span>
          <span class="badge bg-primary ms-2">
            <%= member.earned_points %> earned
          </span>
          <span class="badge bg-danger ms-2">
            <%= member.spent_points %> spent
          </span>
        </div>

        <% member_rewards = @rewards.select { |r| r.user_id == member.id } %>
        <% if member_rewards.any? %>
          <% member_rewards.each do |reward| %>
            <div class="card mb-3 <%= 'border-success' if reward.redeemed? %>" style="height: 180px;">
              <div class="row g-0 h-100">
                <div class="col-4" style="background-color: #f8f9fa;">
                  <% if reward.photo.attached? %>
                    <%= image_tag reward.photo, class: "w-100 h-100", style: "object-fit: cover;" %>
                  <% else %>
                    <div class="d-flex align-items-center justify-content-center h-100 text-secondary">
                      <i class="bi bi-gift fs-1"></i>
                    </div>
                  <% end %>
                </div>
                <div class="col-8">
                  <div class="card-body d-flex flex-column h-100 py-2">
                    <h5 class="card-title text-truncate mb-1"><%= reward.name %></h5>
                    <p class="card-text small flex-grow-1 mb-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= reward.description %></p>
                    <p class="mb-2"><span class="badge bg-primary"><%= reward.reward_points %> pts</span></p>
                    <div class="d-flex flex-wrap gap-1 mt-auto">
                      <% if reward.redeemed? %>
                        <span class="badge bg-success align-self-center">Redeemed</span>
                      <% else %>
                        <%= link_to "Redeem", redeem_reward_path(reward),
                            data: { turbo_method: :patch },
                            class: "btn btn-outline-success btn-sm" %>
                      <% end %>
                      <%= link_to "Edit", edit_reward_path(reward), class: "btn btn-outline-primary btn-sm" %>
                      <%= link_to "Delete", reward_path(reward),
                          data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                          class: "btn btn-outline-danger btn-sm" %>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted">No rewards yet for this member.</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
