<div class="entry-form-page bg-info-subtle min-vh-100 py-4">
  <div class="container" style="max-width: 720px;">
    <%= link_to rewards_path, class: "btn btn-sm btn-light rounded-pill mb-3" do %>
      <i class="bi bi-arrow-left me-1"></i> Back to rewards
    <% end %>

    <div class="card bg-white rounded-5 border-0 shadow-sm p-4" data-controller="reward-template">
      <h1 class="h4 fw-bold mb-4">Create a reward</h1>
      <%= render "library_picker", reward_templates: @reward_templates %>
      <%= render "form", reward: @reward, family_members: @family_members %>
    </div>
  </div>
</div>
