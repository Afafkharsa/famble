<div class="container mt-4" data-controller="reward-template">
  <div class="row justify-content-center">
    <div class="col-12 col-md-9 col-lg-7">

      <% if @reward_templates.any? %>
        <p class="fw-bold small text-uppercase mb-2" style="letter-spacing: 0.04em; color: rgba(14,0,0,0.4);">Reward Library</p>
        <div class="row g-2 mb-4">
          <% @reward_templates.each do |template| %>
            <div class="col-4 col-md-3">
              <div class="reward-template-card"
                   data-action="click->reward-template#fill"
                   data-template-id="<%= template.id %>"
                   data-template-name="<%= template.name %>"
                   data-template-photo-url="<%= template.photo.attached? ? url_for(template.photo) : '' %>"
                   data-template-reward-points="<%= template.reward_points %>"
                   data-template-icon="<%= template.icon %>">
                <% if template.photo.attached? %>
                  <%= image_tag template.photo, class: "reward-template-card__img" %>
                <% elsif template.icon.present? %>
                  <i class="bi bi-<%= template.icon %>" style="font-size: 22px; color: rgba(14,0,0,0.3); display: block; margin-bottom: 6px;"></i>
                <% end %>
                <p class="reward-template-card__name"><%= template.name %></p>
                <p class="reward-template-card__pts"><%= template.reward_points %> pts</p>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="form-page-wrapper">
        <div class="form-card">
          <%= render "shared/back_link", url: root_path %>
          <h2 class="form-card-title">New Reward</h2>
          <%= render "form", reward: @reward, family_members: @family_members %>
        </div>
      </div>

    </div>
  </div>
</div>
