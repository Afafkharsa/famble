<% progress_pct = reward.reward_points > 0 ? [[member.available_points * 100 / reward.reward_points, 0].max, 100].min : 100 %>
<% pts_remaining = reward.reward_points - member.available_points %>
<% can_redeem = member.available_points >= reward.reward_points %>

<div class="reward-item">
  <div class="reward-item__top">

    <%# Icon circle — uses member's pastel color as bg %>
    <div class="reward-item__icon" style="background: <%= color %>;">
      <% if reward.photo.attached? %>
        <%= image_tag reward.photo %>
      <% elsif reward.icon.present? %>
        <i class="bi bi-<%= reward.icon %> reward-item__bi-icon"></i>
      <% else %>
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.4;">
          <rect x="3" y="8" width="18" height="13" rx="2"/>
          <path d="M12 8V3"/>
          <path d="M8 3c0 2 4 5 4 5s4-3 4-5"/>
        </svg>
      <% end %>
    </div>

    <div class="reward-item__info">
      <p class="reward-item__name"><%= reward.name %></p>
      <p class="reward-item__desc"><%= reward.description %></p>
    </div>

    <%# Bootstrap dropdown for edit/delete — hidden until row hovered (CSS) %>
    <div class="dropdown reward-three-dot">
      <button data-bs-toggle="dropdown" aria-expanded="false" aria-label="Options">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="opacity: 0.4;">
          <circle cx="8" cy="3" r="1.2"/>
          <circle cx="8" cy="8" r="1.2"/>
          <circle cx="8" cy="13" r="1.2"/>
        </svg>
      </button>
      <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size: 12px; min-width: 130px; border-radius: 10px;">
        <li>
          <%= link_to edit_reward_path(reward), class: "dropdown-item d-flex align-items-center gap-2" do %>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.5;">
              <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>
            </svg>
            Edit
          <% end %>
        </li>
        <li>
          <%= link_to reward_path(reward),
              data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
              class: "dropdown-item d-flex align-items-center gap-2 text-danger" do %>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            </svg>
            Delete
          <% end %>
        </li>
      </ul>
    </div>

  </div>

  <%# Bottom row: progress + action button %>
  <div class="reward-item__bottom">
    <% if reward.redeemed %>
      <span class="badge bg-success" style="font-size: 10px;">Redeemed</span>
    <% else %>
      <div class="reward-item__progress">
        <div class="d-flex justify-content-between mb-1">
          <span style="font-size: 11px; font-weight: 700;"><%= member.available_points %> / <%= reward.reward_points %></span>
          <% if can_redeem %>
            <span class="text-success" style="font-size: 10px; font-weight: 700;">Ready!</span>
          <% else %>
            <span class="text-muted" style="font-size: 10px;"><%= pts_remaining %> more</span>
          <% end %>
        </div>
        <div class="progress" style="height: 6px;">
          <div class="progress-bar" role="progressbar"
               style="width: <%= progress_pct %>%; background-color: <%= color %>;"></div>
        </div>
      </div>

      <% if can_redeem %>
        <%= link_to redeem_reward_path(reward),
            data: { turbo_method: :patch },
            class: "btn btn-sm btn-success" do %>
          Redeem
        <% end %>
      <% else %>
      <% end %>
    <% end %>
  </div>
</div>
