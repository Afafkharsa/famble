
  <div class="row g-0 border-0 shadow-sm h-100 bg-white rounded-4 card">
    <div class="col-md-4 bg-light h-100 rounded-4" >
      <% if reward.photo.attached? %>
        <%= image_tag reward.photo, class: "w-100 h-100", style: "object-fit: cover;" %>
      <% else %>
        <div class="d-flex align-items-center justify-content-center h-100 text-secondary">
          <i class="bi bi-gift fs-1"></i>
        </div>
      <% end %>
    </div>
    <div class="col-8">
      <div class="card-body d-flex flex-column h-100 py-2">
        <h5 class="card-title text-truncate mb-1"><%= reward.name %></h5>
        <p class="card-text small flex-grow-1 mb-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= reward.description %></p>
        <p class="mb-2"><span class="badge bg-primary"><%= reward.reward_points %> pts</span></p>
        <div class="d-flex justify-content-center flex-wrap gap-1 mt-auto justify-content center">
          <% if reward.redeemed? %>
            <button  type="button" class="btn btn-outline-secondary btn-sm rounded-2" disabled>
              <i class="fa-solid fa-gem"></i>
            </button>
          <% else %>
            <%= link_to redeem_reward_path(reward),
                data: { turbo_method: :patch },
                class: "btn btn-outline-success btn-sm rounded-2" do %>
              <i class="fa-solid fa-download"></i>
            <% end %>
          <% end %>
          <%= link_to edit_reward_path(reward), class: "btn btn-outline-primary btn-sm" do %>
            <i class="fas fa-pen"></i>
          <% end %>
          <%= link_to reward_path(reward),
              data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
              class: "btn btn-outline-danger btn-sm  rounded-2" do %>
            <i class="bi bi-trash"></i>
          <% end %>
        </div>
      </div>
    </div>
  </div>
