<div class="card-body">
  <button type="button" class="btn-close float-end me-3" data-bs-dismiss="modal"></button>
  <h1 class="mt-4 mb-2 text-center fw-bold">Edit Member</h1>

  <div class="modal-body p-4">
    <%= simple_form_for(@member, url: family_path(@member), method: :patch) do |f| %>
      <div class="mx-auto mb-3" style="width: 120px; height: 120px; border-radius: 50%; background: #eee; overflow: hidden; border: 2px dashed #ccc; position: relative;">
        <div class="mt-4"></div>
        <%= f.input :photo %>
      </div>
      <div class="text-start">
        <%= f.input :role, collection: ['Parent', 'Child'], prompt: "Select Relationship", input_html: { class: "form-select bg-light border-0 rounded-4" }, label: "Relationship" %>
      </div>
      <div class="text-start">
        <%= f.input :name, label: "Name", placeholder: "Enter name", input_html: { class: "bg-light border-0 rounded p-2" } %>
      </div>
      <div class="text-start">
        <%= f.input :birthdate, as: :string, label: "Birthday", placeholder: "DD/MM/YY", input_html: { class: "bg-light border-0 rounded p-2", type: "date" } %>
      </div>

      <div class="d-flex justify-content-center">
        <%= f.button :submit, "Save", class: "btn btn-primary w-auto px-5 py-2 mb-4 mt-3 rounded-pill fs-5" %>
      </div>
    <% end %>
  </div>
</div>
