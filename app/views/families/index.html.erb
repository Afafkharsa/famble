<div class="main-container ms-5">
  <div class="family-container mt-4">
    <div class="d-flex justify-content-left gap-3 align-items-center mb-5 ms-5">
      <h1 class="fw-bold m-0">My Family</h1>
      <button class="btn btn-outline-dark rounded-circle d-flex align-items-center justify-content-center"
                onclick="addNewMember()"
                style="width: 50px; height: 50px; border-width: 2px; font-weight: bold;">+</button>
    </div>

    <!--Member photo -->
    <div class="row gx-2 gy-2">
      <% @members.each do |member| %>
        <div class="col-auto text-center ms-5">
          <div class="member-wrapper" onclick="selectMember('<%= member.name %>')" style="cursor: pointer;">
            <div class="photo-circle mx-auto mb-2 shadow-sm d-flex align-items-center justify-content-center
              fs-3 fw-bold" style="width: 100px; height: 100px; background-color: #6c757d; border-radius: 50%;
              overflow: hidden; border: 2px solid #eee; font-size: 16px;">

              <% if member.photo.attached? %>
                <%= image_tag member.photo, style: "width: 100%; height: 100%; object-fit: cover;" %>
              <% else %>
                <div style="color: white; font-size: 0.8rem;">Photo</div>
              <% end %>
            </div>

          <!--Member name -->
            <span class="member-name fw-semibold" style="font-size: 1.5rem; color: #333;">
              <%= link_to member.name, "#" , style:"text-decoration:none;"%>
            </span>
          </div>
        </div>
        <% end %>
    </div>

    <div class="mt-5 ms-5">
      <%= link_to "Reward & Progress", "#", class:"btn-success" %>
    </div>
  </div>
</div>
