<%= simple_form_for(@meal_plan) do |f| %>

  <%= f.input :day, as: :date, html5: true, label: "Date",
      wrapper_html: { class: "mb-3" } %>

  <%= f.simple_fields_for :recipe_meal_plans do |rmp| %>
    <%= rmp.input :meal_type,
        collection: ["Breakfast", "Lunch", "Dinner", "Snack"],
        prompt: "Select meal type", label: "Meal type",
        wrapper_html: { class: "mb-3" } %>
    <%= rmp.association :recipe, label: "Recipe", prompt: "Select a recipe",
        wrapper_html: { class: "mb-3" } %>
  <% end %>

  <%= f.input :photo, as: :file, label: "Photo",
      wrapper_html: { class: "mb-4" } %>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "btn btn-primary rounded-4" %>
    <%= link_to "Cancel", meal_plans_path, class: "btn btn-outline-secondary rounded-4" %>
  </div>

<% end %>
