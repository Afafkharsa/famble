<div class="meal-plans-page">
  <div class="container py-4 pb-5">

    <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-4">
      <div>
        <h1 class="h3 fw-bold mb-1">Meal plans</h1>
        <p class="text-muted small mb-0">What's on the table today and this week</p>
      </div>
      <%= link_to "+ Add meal", new_meal_plan_path, class: "btn btn-dark" %>
    </div>

    <%# ---Today--- %>
    <section class="mb-4">
      <h2 class="h5 fw-bold mb-3 text-muted text-uppercase small">Today</h2>
      <div class="card border-0 shadow-sm rounded-5 bg-white">
        <div class="card-body p-4">
          <%= render "meal_row", plan: @today_plan, date: Date.today %>
        </div>
      </div>
    </section>

    <%# --- This week --- %>
    <section>
      <h2 class="h5 fw-bold mb-3 text-muted text-uppercase small">This week</h2>
      <div class="card border-0 shadow-sm rounded-5 bg-white">
        <div class="card-body p-4">
          <% @weekly_plans.each_with_index do |plan, index| %>
            <%= render "meal_row", plan: plan, date: plan.day %>
            <% unless index == @weekly_plans.size - 1 %>
              <hr class="my-3">
            <% end %>
          <% end %>
          <% if @weekly_plans.empty? %>
            <p class="text-muted fst-italic text-center mb-0">Nothing planned yet this week.</p>
          <% end %>
        </div>
      </div>
    </section>
  </div>
</div>
