<% # ใช้ container หลักเพียงอันเดียวครอบทั้งหมด เพื่อความเท่ากัน %>
<div class="container py-5">

  <% # ---Today's Meal Plan --- %>
  <div class="meal-plan-section mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1 class="display-5 fw-bold mb-0">Today's Meal Plan</h1>
      <%= link_to "Add Meal", new_meal_plan_path, class: "btn btn-primary rounded-pill px-4" %>
    </div>

    <div class="table-responsive shadow-lg rounded-3 bg-white p-4">
      <table class="table table-borderless align-middle text-center mb-0">
        <thead class="text-secondary small">
          <tr class="fs-6">
            <th style="width: 15%;"></th>
            <th style="width: 21.25%;"><i class="bi bi-sun-fill text-warning d-block fs-4 mb-1"></i>Breakfast</th>
            <th style="width: 21.25%;"><i class="bi bi-egg-fried text-info d-block fs-4 mb-1"></i>Lunch</th>
            <th style="width: 21.25%;"><i class="bi bi-moon-stars-fill text-primary d-block fs-4 mb-1"></i>Dinner</th>
            <th style="width: 21.25%;"><i class="bi bi-apple text-danger d-block fs-4 mb-1"></i>Snack</th>
          </tr>
        </thead>
        <tbody>
          <% # บรรทัดที่ 24: %>
            <% if @today_plan %>
            <tr>
              <td class="fw-bold align-middle text-secondary" style="width: 100px;">
                <%= @today_plan.day.strftime("%A, %d %b") %>
              </td>

              <% meal_types = ["Breakfast", "Lunch", "Dinner", "Snack"] %>
              <% meal_types.each do |type| %>
              <td class="p-4">
                <% # ค้นหาว่ามีมื้ออาหารประเภทนี้ในวันนี้ไหม %>
                <% meal = @today_plan.recipe_meal_plans.find { |rmp| rmp.meal_type == type } %>

                  <% if meal %>
                    <div class="text-center">
                      <%= link_to recipe_path(meal.recipe), class:"text-decoration-none" do %>
                        <% # ดึงรูปภาพจาก Recipe (ถ้ามี) %>
                        <%# if meal.recipe.image_url.present? %>
                        <img src="http://via.placeholder.com/150"<%#= meal.recipe.image_url %> class="shadow-sm mb-2" style="width: 70px; height: 70px; object-fit: cover;">
                        <%# else %>
                        <img src="http://via.placeholder.com/150"<%#= meal.recipe.image_url %> class="shadow-sm mb-2" style="width: 70px; height: 70px; object-fit: cover;">
                        <%# end %>
                      <div class="small fw-bold"><%= meal.recipe.name %></div>
                    </div>
                    <% end %>
                  <% else %>
                    <%= link_to "+", new_meal_plan_path(@today_plan), class: "btn btn-outline-light text-muted btn-sm rounded-circle" %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>

        </tbody>
      </table>
    </div>
  </div>

  <% # --- ส่วน Weekly's Meal Plan --- %>
  <div class="meal-plan-section">
    <h1 class="display-5 fw-bold mb-4">Weekly's Meal Plan</h1>
    <div class="d-flex justify-content-between table-responsive shadow-lg rounded-3 bg-white p-4">
      <table class="table table-borderless align-middle text-center mb-0">
        <thead class="text-secondary small">
          <tr class="fs-6">
            <th style="width: 15%;"></th>
            <th style="width: 21.25%;"><i class="bi bi-sun-fill text-warning d-block fs-4 mb-1"></i>Breakfast</th>
            <th style="width: 21.25%;"><i class="bi bi-egg-fried text-info d-block fs-4 mb-1"></i>Lunch</th>
            <th style="width: 21.25%;"><i class="bi bi-moon-stars-fill text-primary d-block fs-4 mb-1"></i>Dinner</th>
            <th style="width: 21.25%;"><i class="bi bi-apple text-danger d-block fs-4 mb-1"></i>Snack</th>
          </tr>
        </thead>
        <tbody>
          <% # ใส่โค้ด Loop รายวัน (Day 1 - Day 7) ที่นี่ %>
            <% # บรรทัดที่ 48: วนลูปรายวัน 7 วัน %>
              <% @weekly_plans.each do |meal_plan| %>
                <tr>
                  <td class="fw-bold fs-6 align-middle text-secondary text-success" style="width: 100px;">
                    <%= meal_plan.day.strftime("%A, %d %b") %>
                  </td>

                  <% meal_types = ["Breakfast", "Lunch", "Dinner", "Snack"] %>
                  <% meal_types.each do |type| %>
                    <td class="p-3">
                      <% meal = meal_plan.recipe_meal_plans.find { |rmp| rmp.meal_type == type } %>

                      <% if meal %>
                        <div class="recipe-thumbnail text-center">
                          <%= link_to recipe_path(meal.recipe), class:"text-decoration-none" do %>
                          <% # ดึงรูปภาพจาก Recipe (ถ้ามี) %>
                          <%# if meal.recipe.image_url.present? %>
                            <img src="http://via.placeholder.com/150"<%#= meal.recipe.image_url %> class="shadow-sm mb-2" style="width: 70px; height: 70px; object-fit: cover;">
                            <%# else %>
                            <img src="http://via.placeholder.com/150"<%#= meal.recipe.image_url %> class="shadow-sm mb-2" style="width: 70px; height: 70px; object-fit: cover;">
                            <%# end %>
                          <div class="small fw-bold">
                            <%= meal.recipe.name %>
                          </div>
                        </div>
                        <% end %>
                      <% else %>
                        <%= link_to "+", new_meal_plan_path(day: meal_plan.day, meal_type: type), class: "btn btn-outline-light text-muted btn-sm rounded-circle" %>
                      <% end %>
                    </td>
                  <% end %>
                </tr>
              <% end %>
        </tbody>
      </table>
    </div>
  </div>

</div>
