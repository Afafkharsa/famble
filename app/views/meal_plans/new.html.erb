<div class="entry-form-page bg-info-subtle min-vh-100 py-4">
  <div class="container" style="max-width: 720px;">
    <%= link_to meal_plans_path, class: "btn btn-sm btn-light rounded-pill mb-3" do %>
      <i class="bi bi-arrow-left me-1"></i> Back to meal plans
    <% end %>

    <div class="card bg-white rounded-5 border-0 shadow-sm p-4">
      <h1 class="h4 fw-bold mb-4">Create a meal plan</h1>
      <%= render "form", meal_plan: @meal_plan %>
    </div>
  </div>
</div>
