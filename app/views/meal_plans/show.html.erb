<%# app/views/meal_plans/show.html.erb %>
<h1>Meal Plan for <%= @meal_plan.day %></h1>

<div class="meal-details">
  <% @meal_plan.recipe_meal_plans.each do |item| %>
    <div class="card mb-3">
      <div class="card-body">
        <h5 class="text-primary"><%= item.meal_type %></h5>

        <%# ดึงข้อมูลจากตาราง Recipe มาแสดง %>
        <h3><%= item.recipe.name %></h3>
        <p>Calories: <%= item.recipe.calories %> kcal</p>

        <%# สร้างลิงก์กลับไปยังหน้า Recipe Show %>
        <%= link_to "View Full Recipe", recipe_path(item.recipe), class: "btn btn-sm btn-info" %>
      </div>
    </div>
  <% end %>
</div>
