<nav class="navbar navbar-expand-md navbar-light bg-white border-bottom shadow-sm sticky-top <%= yield(:navbar_class) %>">
  <div class="container-fluid">
    <% if current_user && current_user.role %>
      <%= link_to root_path, class: "navbar-brand fw-bold" do %>
        Famble
      <% end %>
    <% else %>
      <%= link_to root_path, class: "navbar-brand fw-bold text-white" do %>
        Famble
      <% end %>
    <% end %>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
            data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
            aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <% if user_signed_in? && current_user.role %>
        <ul class="navbar-nav mx-auto gap-md-2">
          <li class="nav-item">
            <%= link_to root_path, class: "nav-link d-flex align-items-center #{'active fw-bold' if current_page?(root_path)}",
                aria: { label: "Home" }, title: "Home" do %>
              <i class="bi bi-house-door"></i>
            <% end %>
          </li>
          <li class="nav-item">
            <%= link_to "Tasks", tasks_path, class: "nav-link #{'active fw-bold' if current_page?(controller: 'tasks')}" %>
          </li>
          <li class="nav-item">
            <%= link_to "Rewards", rewards_path, class: "nav-link #{'active fw-bold' if current_page?(controller: 'rewards')}" %>
          </li>
          <li class="nav-item">
            <%= link_to "Meal plans", meal_plans_path, class: "nav-link #{'active fw-bold' if current_page?(controller: 'meal_plans')}" %>
          </li>
          <li class="nav-item">
            <%= link_to "Recipes", recipes_path, class: "nav-link #{'active fw-bold' if current_page?(controller: 'recipes')}" %>
          </li>
          <li class="nav-item">
            <%= link_to "Calendar", calendars_path, class: "nav-link #{'active fw-bold' if current_page?(controller: 'calendars')}" %>
          </li>
        </ul>

        <ul class="navbar-nav ms-auto">
          <li class="nav-item dropdown">
            <a href="#" class="nav-link d-flex align-items-center gap-2 dropdown-toggle"
               id="navbarDropdown" data-bs-toggle="dropdown" aria-expanded="false">
              <span class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold overflow-hidden"
                    style="width: 32px; height: 32px; background: <%= current_user.avatar_color %>; font-size: 0.75rem;">
                <% if current_user.photo.attached? %>
                  <%= image_tag current_user.photo, style: "width: 100%; height: 100%; object-fit: cover;" %>
                <% else %>
                  <%= current_user.initials %>
                <% end %>
              </span>
              <span class="d-none d-lg-inline small"><%= current_user.display_name %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4" aria-labelledby="navbarDropdown">
              <li class="px-3 py-2 small text-muted"><%= current_user.email %></li>
              <li><hr class="dropdown-divider"></li>
              <% if current_user.parent? %>
                <li><%= link_to "My family", families_path, class: "dropdown-item" %></li>
              <% end %>
              <li>
                <%= link_to destroy_user_session_path, data: { turbo_method: :delete },
                    class: "dropdown-item" do %>
                  <i class="bi bi-box-arrow-right me-2"></i>Log out
                <% end %>
              </li>
            </ul>
          </li>
        </ul>
      <% elsif user_signed_in? %>
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete },
                class: "nav-link" do %>
              <i class="bi bi-box-arrow-right me-1"></i>Log out
            <% end %>
          </li>
        </ul>
      <% else %>
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <%= link_to "Log in", new_user_session_path, class: "nav-link" %>
          </li>
          <li class="nav-item">
            <%= link_to "Sign up", new_user_registration_path, class: "nav-link btn btn-dark text-white ms-md-2 px-3" %>
          </li>
        </ul>
      <% end %>
    </div>
  </div>
</nav>
