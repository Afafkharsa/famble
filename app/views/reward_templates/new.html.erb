<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-12 col-md-9 col-lg-7">
      <div class="form-page-wrapper">
        <div class="form-card">
          <h2 class="form-card__title">Add to Library</h2>
          <%= form_with(model: @reward_template) do |f| %>
            <div class="mb-3">
              <%= f.label :name, "Name", class: "form-label" %>
              <%= f.text_field :name, class: "form-control", placeholder: "e.g. Movie night" %>
            </div>
            <div class="mb-3">
              <%= f.label :icon, "Icon", class: "form-label" %>
              <div class="reward-icon-picker">
                <% %w[gift star-fill trophy-fill controller film book music-note-beamed bicycle palette bag heart-fill sun lightning-fill award emoji-smile camera headphones cup-hot balloon-heart people-fill].each do |icon| %>
                  <button type="button" class="icon-option <%= @reward_template.icon == icon ? 'icon-option--active' : '' %>"
                          onclick="this.closest('form').querySelector('#icon-input').value = this.dataset.icon; this.closest('.reward-icon-picker').querySelectorAll('.icon-option').forEach(b => b.classList.remove('icon-option--active')); this.classList.add('icon-option--active');"
                          data-icon="<%= icon %>">
                    <i class="bi bi-<%= icon %>"></i>
                  </button>
                <% end %>
              </div>
              <%= f.hidden_field :icon, id: "icon-input" %>
            </div>
            <div class="mb-3">
              <%= f.label :description, "Description", class: "form-label" %>
              <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Describe the reward..." %>
            </div>
            <div class="mb-3">
              <%= f.label :reward_points, "Points required", class: "form-label" %>
              <%= f.number_field :reward_points, class: "form-control", min: 0 %>
            </div>
            <div class="mb-4">
              <%= f.label :photo, class: "form-label" %>
              <span class="text-muted small ms-1">(optional)</span>
              <%= f.file_field :photo, class: "form-control", accept: "image/*" %>
            </div>
            <div class="d-flex gap-2">
              <%= f.submit "Add to Library", class: "btn btn-primary" %>
              <%= link_to "Cancel", reward_templates_path, class: "btn btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
