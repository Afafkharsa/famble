<%= form_with(model: reward_template) do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control", placeholder: "e.g. Movie night" %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 3, placeholder: "Describe the reward..." %>
  </div>

  <div class="mb-3">
    <%= f.label :reward_points, "Points required", class: "form-label" %>
    <%= f.number_field :reward_points, class: "form-control", min: 0 %>
  </div>

  <div class="mb-3">
    <%= f.label :icon, "Icon", class: "form-label" %>
    <div class="icon-picker">
      <% Reward::ICON_OPTIONS.each do |slug| %>
        <label class="icon-picker__option">
          <%= f.radio_button :icon, slug, class: "icon-picker__radio" %>
          <span class="icon-picker__tile">
            <%= lucide_icon slug, class: "icon-picker__svg" %>
          </span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="mb-3">
    <%= f.label :photo, "Photo (optional)", class: "form-label" %>
    <%= f.file_field :photo, class: "form-control", accept: "image/*" %>
  </div>

  <%= f.submit class: "btn btn-dark" %>
<% end %>
