
<div id="<%= dom_id(member) %>" class="col-auto text-center ms-5">
  <%= link_to family_member_path(member.family, member),
              data: { turbo_frame: "modal" },
              class: "text-decoration-none text-dark" do %>

    <div class="member-wrapper" style="cursor: pointer;">

    <%# Photo %>
      <div class="photo-circle mx-auto mb-2 shadow-sm d-flex align-items-center justify-content-center"
           style="width: 120px; height: 120px; background-color: #5f84a4; border-radius: 50%; overflow: hidden; border: 2px solid #eee;">
        <% if member.photo.attached? %>
          <%= image_tag member.photo, style: "width: 100%; height: 100%; object-fit: cover;" %>
        <% else %>
          <div style="color: white; font-size: 0.8rem;">Photo</div>
        <% end %>
      </div>

    <%# Name %>
      <span class="member-name fw-semibold d-block" style="font-size: 1.5rem;">
        <%= member.name %>
      </span>

    </div>
  <% end %>
</div>
