
<div class="container py-5">

  <div class="family-section mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div class="d-flex align-item-center gap-3">
        <h1 class="fw-bold m-0 ms-3">My Family</h1>
        <i class="fa-solid fa-house text-light-emphasis d-block fs-1 mb-1"></i>
        <div>
          <%= link_to new_family_member_path(@family),
                data: { turbo_frame: "modal" },
                class: "btn btn-outline-primary border-radius-5 d-flex align-items-center justify-content-center",
                style: "width: 150px; height: 50px; border-width: 2px; font-weight: bold;" do %>
              Add member
            <% end %>
          </div>
      </div>

  <div id="member-list" class="d-flex flex-wrap justify-content-start gap-4 gx-2 gy-2">
    <%# @members.each do |member| %>
    <% current_user.family.users.each do |member| %>

      <%# Use dom_id for Turbo when Update/Delete %>
      <div id="<%= dom_id member %>" class="col-auto text-center ms-5">

        <%# Use link_to to cover all name and photo to open Modal %>
        <%= link_to edit_family_member_path(@family, member), data: { turbo_frame: "modal" }, style: "text-decoration: none; color: inherit;" do %>
          <div class="member-wrapper" style="cursor: pointer;">
            <div class="photo-circle mx-auto mb-2 shadow-sm d-flex align-items-center justify-content-center fs-3 mt-3 fw-bold"
                 style="width: 120px; height: 120px; background-color: #5f84a4; border-radius: 50%; overflow: hidden; border: 2px solid #eee; font-size: 16px;">
              <% if member.photo.attached? %>
                <%= image_tag member.photo, style: "width: 100%; height: 100%; object-fit: cover;" %>
              <% else %>
                <div style="color: white; font-size: 0.8rem;">Photo</div>
              <% end %>
            </div>

            <span class="member-name fw-semibold" style="font-size: 1.5rem; color: #333;">
              <%= member.name.presence || "No name" %>
            </span>
          </div>
        <% end %>

      </div>
    <% end %>

  </div>
</div>

<%= turbo_frame_tag "modal" %>


    <div class="d-flex gap-3 ms-3 mt-5">
      <%= link_to "Reward & Progress", rewards_path, class:"btn btn-success border-radius-5 align-items-center py-3", style:"w-auto;" %>
    </div>
  </div>

</div>
