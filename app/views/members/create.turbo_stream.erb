
<%# 1. เอาสมาชิกใหม่ไปแปะต่อท้ายลิสต์ %>
<%= turbo_stream.append "member-list", partial: "members/member", locals: { member: @member } %>
<%= turbo_stream.update "modal-content-area", "" %>

<%# 2. สั่งปิด Modal (ใช้ ID ของ Modal คุณ เช่น memberModal) %>
<script>
  (function() {
    const modalElement = document.getElementById('memberModal');
    const modal = bootstrap.Modal.getInstance(modalElement);
    if (modal) {
      modal.hide();
    }

    // ลบฉากหลัง (Backdrop) ที่ค้างอยู่ทั้งหมดออกไป
    document.querySelectorAll('.modal-backdrop').forEach(el => el.remove());

    // คืนค่า Body ให้เลื่อนหน้าจอได้ปกติ
    document.body.classList.remove('modal-open');
    document.body.style.overflow = 'auto';
    document.body.style.paddingRight = '0';
  })();
</script>
