
<%# Put new member at last %>
    <%= turbo_stream.append "member-list", partial: "members/member", locals: { member: @member } %>

<%# Close Modal %>
<%#= turbo_stream.update "modal", "" %>
<%= turbo_stream.replace "modal" do %>
  <turbo-frame id="modal"></turbo-frame>
<% end %>

