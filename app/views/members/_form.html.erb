<div class="modal-body p-4 text-center">

  <%= simple_form_for(@member,
                      url: @member.persisted? ?
                      family_member_path(@family, @member) :
                      family_members_path(@family)) do |f| %>

    <div class="mx-auto mb-3" style="width: 120px; height: 120px; border-radius: 50%;
         background: #eee; overflow: hidden; border: 2px dashed #ccc; position: relative;">
      <div class="mt-4"></div>
      <%= f.input :photo %>
    </div>

  <%#= Select Relationship %>
    <div class="text-start">
      <%= f.input :role, collection: ['Parent', 'Child'], prompt:"Select Relationship", input_html: { class:"form-select bg-light border-0 rounded-4" }, label: "Relationship" %>
    </div>

  <%#= Add email %>
    <div class="text-start fw-bold">
      <%= f.input :email, label: "E-mail", placeholder: "Enter member's email", input_html: { class: "bg-light border-0 rounded p-2" } %>
    </div>

  <%#= Add name %>
    <div class="text-start">
      <%= f.input :name, label: "Name", placeholder: "Enter name", input_html: { class: "bg-light border-0 rounded p-2" } %>
    </div>

  <%#= Select Birth date %>
    <div class="text-start">
      <%= f.input :birthdate, as: :date, label: "Birthday", placeholder: "DD/MM/YY", input_html: { class: "bg-light border-0 rounded p-2", type: "date" } %>
    </div>

      <%= f.button :submit, class: "btn btn-primary w-auto py-2 mt-3 border-radius-5 fs-5" %>

  <% end %>
</div>
