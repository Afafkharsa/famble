<div class="p-4">

  <%= simple_form_for @member,
                      url: (@member.persisted? ?
                      family_member_path(@family, @member) :
                      family_members_path(@family)),
                      method: (@member.persisted? ? :patch : :post) do |f| %>
    <% photo_name = "user_#{@member.name.downcase}.jpg" %>
    <label for="member_photo_input" style="cursor: pointer;">
      <div class="mx-auto mt-0 mb-4" style="width: 120px; height: 120px; border-radius: 50%; background-image: url('<%= asset_path(photo_name) %>'); background-size: cover; background-position: center; overflow: hidden; border: 2px solid #ccc;">
      <small class="text-mute"></small>
    </label>

      <%= f.input :photo, label: false, input_html: { id: "member_photo_input", style: "display: none;" } %>
    </div>

    <%= f.input :role, collection: ['Parent', 'Child'], prompt: "Select relationship",
        input_html: { class: "form-select" }, label: "Relationship",
        wrapper_html: { class: "mb-3 text-start" } %>

    <%= f.input :email, label: "Email", placeholder: "Enter email",
        wrapper_html: { class: "mb-3 text-start" } %>

    <%= f.input :name, label: "Name", placeholder: "Enter name",
        wrapper_html: { class: "mb-3 text-start" } %>

    <%= f.input :birthdate, as: :date, label: "Birthday",
        input_html: { class: "form-control", type: "date" },
        wrapper_html: { class: "mb-4 text-start" } %>

    <%= f.button :submit, class: "btn btn-primary rounded-4 w-100" %>

  <% end %>
</div>
