
<%= turbo_frame_tag "modal" do %>
  <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1" style="display: block;">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title fs-2 fw-bold text-center" >Edit Member111
              <%= link_to family_member_path(@family, @member),
                  data: { turbo_method: :delete,
                  turbo_confirm: "Are you sure?" },
                  class:"text-dark" do %>
              <i class="bi bi-trash fs-5 ms-3"></i>
              <% end %>
            </h5>

        <%# Colse button of modal %>
            <button type="button" class="btn-close"
                    onclick="const frame = this.closest('turbo-frame');
                    frame.src = ''; frame.innerHTML = '';">
            </button>
          </div>
          <div class="modal-body">
            <%= render "form", member: @member %>
          </div>
      </div>
    </div>
  </div>
<% end %>
