<div class="container py-5">

  <div class="card shadow-sm overflow-hidden">

    <% if @recipe.photo.attached? %>
      <%= image_tag @recipe.photo,
          class: "img-fluid mb-3",
          style: "object-fit: cover; max-height: 300px; width: 100%;" %>
    <% end %>

    <div class="card-body">

      <div class="d-flex align-items-center mb-3 mt-3">
        <h1 class="card-title mb-0 me-4"><%= @recipe.name %></h1>

        <%= link_to edit_recipe_path(@recipe), class: "btn btn-outline-secondary btn-sm rounded-pill px-3 ms-2" do %>
          <i class="fas fa-pen me-1"></i> Edit
        <% end %>

        <div class="ms-auto">
          <%= link_to "", recipes_path, class: "btn-close link-underline link-underline-opacity-0 m-2 px-4", aria: { label: "Close" } %>
        </div>
      </div>

      <p class="mb-3">
        <% @recipe.keywords.to_s.split(",").each do |keyword| %>
          <span class="badge rounded-pill bg-secondary-subtle text-secondary px-3 py-2 me-1">
            <%= keyword %>
          </span>
        <% end %>
      </p>

      <p class="text-muted mb-1">
        <i class="fas fa-fire me-1"></i><%= @recipe.calories %> kcal &nbsp;| &nbsp;
        <i class="fas fa-exclamation-triangle me-1"></i>
        <%= @recipe.allergens.present? ? @recipe.allergens : "No allergens" %>
      </p>
      <hr>

      <h3 class="h5 text-secondary fw-bold">Ingredients</h3>
        <ul>
          <% raw = @recipe.ingredients.to_s.strip %>
          <% ingredients = raw.include?("\n") ? raw.split("\n") : raw.split(/, \s(?=[^,]+ + - )/) %>
          <% ingredients.each do |ingredient| %>
            <li><%= ingredient.strip %></li>
          <% end %>
        </ul>

      <h3 class="h5 fw-bold text-secondary mt-4">Description</h3>
        <ol class="mt-2">
           <% @recipe.description.to_s.split("\n").each do |step| %>
             <li><%= step.strip %></li>
           <% end %>
        </ol>
    </div>
  </div>

</div>
