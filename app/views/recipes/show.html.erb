<div class="container py-4 col-md-8">

  <div class="card border-0 shadow-sm overflow-hidden bg-white rounded-4">

    <% if @recipe.photo.attached? %>
      <%= image_tag @recipe.photo,
          class: "img-fluid mb-3",
          style: "object-fit: cover; max-height: 300px; width: 100%;" %>
    <% end %>

    <div class="card-body">

      <%= render "shared/back_link", url: root_path %>

      <div class="d-flex align-items-center my-3">
        <h1 class="card-title me-4 text-success"><%= @recipe.name %></h1>

        <div class="dropdown reward-three-dot reward-three-dot--show ms-2">
          <button data-bs-toggle="dropdown" aria-expanded="false" aria-label="Options">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="opacity: 0.4;">
              <circle cx="8" cy="3" r="1.2"/><circle cx="8" cy="8" r="1.2"/><circle cx="8" cy="13" r="1.2"/>
            </svg>
          </button>
          <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size: 12px; min-width: 130px; border-radius: 10px;">
            <li>
              <%= link_to edit_recipe_path(@recipe), class: "dropdown-item d-flex align-items-center gap-2" do %>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.5;"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
                Edit
              <% end %>
            </li>
            <li>
              <%= link_to recipe_path(@recipe), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "dropdown-item d-flex align-items-center gap-2 text-danger" do %>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                Delete
              <% end %>
            </li>
          </ul>
        </div>

      </div>

      <p class="mb-3">
        <% @recipe.keywords.to_s.split(",").each do |keyword| %>
          <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-2 me-1">
            <%= keyword.strip %>
          </span>
        <% end %>
      </p>

      <p class="text-muted mb-1">
        <i class="fas fa-fire me-1"></i><%= @recipe.calories %> kcal &nbsp;| &nbsp;
        <i class="fas fa-exclamation-triangle me-1"></i>
        <%= @recipe.allergens.present? ? @recipe.allergens : "No allergens" %>
      </p>
      <hr>

      <h3 class="h5 text-primary fw-bold">Ingredients</h3>
        <ul>
          <% raw = @recipe.ingredients.to_s.strip %>
          <% ingredients = raw.include?("\n") ? raw.split("\n") : raw.split(/, \s(?=[^,]+ + - )/) %>
          <% ingredients.each do |ingredient| %>
            <li><%= ingredient.strip %></li>
          <% end %>
        </ul>

      <h3 class="h5 fw-bold text-primary mt-4">Description</h3>
        <ol class="mt-2">
           <% @recipe.description.to_s.split("\n").each do |step| %>
             <li><%= step.strip %></li>
           <% end %>
        </ol>
    </div>
  </div>

</div>
