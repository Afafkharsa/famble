<div class="container py-5">

  <div class="card border-0 shadow-sm overflow-hidden bg-white rounded-4">

    <% if @recipe.photo.attached? %>
      <%= image_tag @recipe.photo,
          class: "img-fluid mb-3",
          style: "object-fit: cover; max-height: 300px; width: 100%;" %>
    <% end %>

    <div class="card-body">

      <div class="d-flex align-items-center my-3">
        <h1 class="card-title me-4 text-success"><%= @recipe.name %></h1>

        <div class="d-flex align-items-center gap-1">
          <%= link_to edit_recipe_path(@recipe), class: "btn text-secondary" do %>
            <i class="bi bi-pencil-square"></i>
          <% end %>

          <%= link_to recipe_path(@recipe),
              data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
              class: "text-muted" do %>
            <i class="bi bi-trash"></i>
          <% end %>
        </div>

        <div class="ms-auto">
          <%= link_to "", recipes_path, class: "btn-close link-underline link-underline-opacity-0 m-2 px-4", aria: { label: "Close" } %>
        </div>
      </div>

      <p class="mb-3">
        <% @recipe.keywords.to_s.split(",").each do |keyword| %>
          <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-2 me-1">
            <%= keyword %>
          </span>
        <% end %>
      </p>

      <p class="text-muted mb-1">
        <i class="bi bi-fire me-1"></i><%= @recipe.calories %> kcal &nbsp;| &nbsp;
        <i class="bi bi-exclamation-triangle me-1"></i>
        <%= @recipe.allergens.present? ? @recipe.allergens : "No allergens" %>
      </p>
      <hr>

      <h3 class="h5 text-primary fw-bold">Ingredients</h3>
        <ul>
          <% raw = @recipe.ingredients.to_s.strip %>
          <% ingredients = raw.include?("\n") ? raw.split("\n") : raw.split(/, \s(?=[^,]+ + - )/) %>
          <% ingredients.each do |ingredient| %>
            <li><%= ingredient.strip %></li>
          <% end %>
        </ul>

      <h3 class="h5 fw-bold text-primary mt-4">Description</h3>
        <ol class="mt-2">
           <% @recipe.description.to_s.split("\n").each do |step| %>
             <li><%= step.strip %></li>
           <% end %>
        </ol>
    </div>
  </div>

</div>
