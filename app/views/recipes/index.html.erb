<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0 d-flex align-items-center gap-4">
      My Recipes
      <%= link_to new_recipe_path, class: "text-decoration-none text-secondary" do %>
        <i class="bi bi-plus-circle fs-4"></i>
      <% end %>
    </h1>
  </div>

  <div class="mb-4">
    <%= form_with url: recipes_path, method: :get, local: true, class: "d-flex" do %>
      <%= text_field_tag :query, params[:query], placeholder: "Search recipes...", class: "form-control me-2 recipe-search-input" %>
      <%= submit_tag "Search", class: "btn btn-outline-primary" %>
    <% end %>
  </div>

  <% if @recipes.any? %>
    <div class="row g-4">
      <% @recipes.each do |recipe| %>
        <div class="col-md-4">
          <div
            class="card border-0 shadow-sm h-100 bg-white rounded-4"
            data-controller="clickable"
            data-clickable-url-value="<%= recipe_path(recipe) %>"
            data-action="click->clickable#go"
            style="cursor: pointer;"
          >
            <div style="height: 150px;">
              <% if recipe.photo.attached? %>
                <%= image_tag recipe.photo,
                    class: "w-100 h-100",
                    style: "object-fit: cover; border-radius: 12px 12px 0 0;" %>
              <% else %>
                <div class="d-flex align-items-center justify-content-center h-100"
                    style="background-color: #e9ecef; border-radius: 12px 12px 0 0;">
                  <i class="fas fa-image text-secondary"></i>
                </div>
              <% end %>
            </div>
            <div class="card-body">
              <h5 class="card-title text-success"><%= recipe.name %></h5>
              <p class="text-muted mb-1" style="font-size: 0.85rem;">
                <i class="fas fa-fire me-1"></i><%= recipe.calories %> kcal &nbsp;| &nbsp;
                <i class="fas fa-exclamation-triangle me-1"></i>
                <%= recipe.allergens.present? ? recipe.allergens : "No allergens" %>
              </p>
              <p class="mb-2">
                <% recipe.keywords.to_s.split(",").first(3).each do |keyword| %>
                  <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-2 me-1">
                    <%= keyword.strip %>
                  </span>
                <% end %>
              </p>
              <div class="mt-auto d-flex justify-content-end gap-2">
                <%= link_to "Add to meal plan", new_meal_plan_path(recipe_id: recipe.id), class: "btn btn-outline-warning btn-sm rounded-pill" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="d-flex justify-content-between">
      <div class="mt-4">
        <p class="text-muted">No recipes saved yet. Ask the AI for a recipe!</p>
      </div>

      <div class="col-md-4 mt-4 text-center">
        <%= render "shared/ai_card" %>
      </div>
    </div>
  <% end %>
</div>
