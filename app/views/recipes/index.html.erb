
<div class="container mt-4">
  <h1 class="text-success text-shadow mb-4">🔖 My Recipes</h1>

  <% if @recipes.any? %>
    <div class="row g-4">
      <% @recipes.each do |recipe| %>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm h-100">
            <% if recipe.photo.present? %>
              <%= image_tag recipe.photo, class: "card-img-top", style: "height: 150px; object-fit: cover; border-radius: 12px 12px 0 0;" %>
            <% end %>
            <div class="card-body">
              <h5 class="card-title text-success"><%= recipe.name %></h5>
              <p class="text-muted mb-1"><i class="fas fa-fire me-1"></i> <%= recipe.calories %> kcal</p>
              <p class="text-muted small"><%= Array(recipe.keywords.split(",")).first(3).join(", ") %></p>
              <div  class="d-flex justify-content-between">
                <%= link_to "View Recipe", recipe_path(recipe), class: "btn btn-outline-success btn-sm rounded-pill" %>
                <%= link_to "Add to meal plan", new_meal_plan_path(recipe_id: recipe.id), class: "btn btn-outline-primary btn-sm rounded-pill" %>
                <%= link_to "Delete recipe", recipe_path(recipe), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm rounded-pill" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">No recipes saved yet. Ask the AI for a recipe!</p>
    <%= link_to "Ask AI for a recipe", chats_path, data: { turbo_method: :post }, class: "btn btn-success rounded-pill" %>
  <% end %>
</div>
