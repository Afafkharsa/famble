<div class="container mt-4">
  <%= link_to root_path, class: "back-link" do %><i class="bi bi-chevron-left"></i> Back<% end %>

  <div class="d-flex align-items-center gap-3 mb-4">
    <h1 class="mb-0">My Recipes</h1>
    <%= link_to new_recipe_path, class: "text-decoration-none text-secondary" do %>
      <i class="bi bi-plus-circle fs-4"></i>
    <% end %>
  </div>

  <div class="mb-4">
    <%= form_with url: recipes_path, method: :get, local: true, class: "d-flex gap-2" do %>
      <%= text_field_tag :query, params[:query],
            placeholder: "Search recipes...",
            class: "form-control recipe-search-input" %>
      <%= submit_tag "Search", class: "recipe-search-btn" %>
    <% end %>
  </div>

  <% if @recipes.any? %>
    <div class="row g-4">
      <% @recipes.each do |recipe| %>
        <div class="col-md-4">
          <div class="recipe-card"
               data-controller="clickable"
               data-clickable-url-value="<%= recipe_path(recipe) %>"
               data-action="click->clickable#go"
               style="cursor: pointer;">

            <% if recipe.photo.attached? %>
              <%= image_tag recipe.photo, class: "recipe-card-img" %>
            <% else %>
              <div class="recipe-card-placeholder">
                <i class="bi bi-image"></i>
              </div>
            <% end %>

            <div class="recipe-card-body">
              <p class="recipe-card-name"><%= recipe.name %></p>

              <div class="recipe-card-meta">
                <span class="d-flex align-items-center gap-1">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                  </svg>
                  <%= recipe.calories %> kcal
                </span>
                <span class="recipe-card-meta-sep">|</span>
                <span class="d-flex align-items-center gap-1">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                  </svg>
                  <%= recipe.allergens.present? ? recipe.allergens : "none" %>
                </span>
              </div>

              <div class="recipe-card-tags">
                <% recipe.keywords.to_s.split(",").first(3).each do |keyword| %>
                  <span class="recipe-card-tag"><%= keyword.strip %></span>
                <% end %>
              </div>

              <div class="d-flex justify-content-end">
                <%= link_to "Add to meal plan",
                      new_meal_plan_path(recipe_id: recipe.id),
                      class: "recipe-card-action-btn" %>
              </div>
            </div>

          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="d-flex justify-content-between">
      <div class="mt-4">
        <p class="text-muted">No recipes saved yet. Ask the AI for a recipe!</p>
      </div>
      <div class="col-md-4 mt-4 text-center">
        <%= render "shared/ai_card" %>
      </div>
    </div>
  <% end %>
</div>
