<%= simple_form_for(recipe) do |f| %>
  <%= f.error_notification %>

  <div class="row g-3">
    <div class="col-md-8">
      <%= f.input :name, label: "Recipe name", placeholder: "e.g. Pancakes" %>
    </div>
    <div class="col-md-4">
      <%= f.input :calories, label: "Calories", as: :integer,
          input_html: { min: 0, placeholder: "kcal" } %>
    </div>
  </div>

  <%= f.input :ingredients, as: :text, label: "Ingredients",
      input_html: { rows: 4, placeholder: "One ingredient per line" } %>

  <%= f.input :description, as: :text, label: "Steps",
      input_html: { rows: 5, placeholder: "Step-by-step instructions" } %>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.input :keywords, label: "Keywords",
          input_html: { placeholder: "comma separated" } %>
    </div>
    <div class="col-md-6">
      <%= f.input :allergens, label: "Allergens",
          input_html: { placeholder: "gluten, dairy, …" } %>
    </div>
  </div>

  <%= f.input :photo, as: :file, label: "Photo (optional)",
      input_html: { accept: "image/*" } %>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit (recipe.persisted? ? "Save changes" : "Create recipe"),
        class: "btn btn-dark" %>
    <%= link_to "Cancel", recipes_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
