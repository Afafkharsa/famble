<%= form_with(model: @recipe, local: true) do |f| %>

  <div class="mb-3">
    <%= f.label :name, "Name", class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :ingredients, "Ingredients", class: "form-label" %>
    <%= f.text_area :ingredients, rows: 3, class: "form-control", placeholder: "One ingredient per line" %>
  </div>

  <div class="mb-3">
    <%= f.label :description, "Instructions", class: "form-label" %>
    <%= f.text_area :description, rows: 3, class: "form-control", placeholder: "Step-by-step instructions" %>
  </div>

  <div class="mb-3">
    <%= f.label :keywords, "Keywords", class: "form-label" %>
    <span class="text-muted small ms-1">(comma separated)</span>
    <%= f.text_field :keywords, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :calories, "Calories (kcal)", class: "form-label" %>
    <%= f.number_field :calories, class: "form-control", min: 0 %>
  </div>

  <div class="mb-3">
    <%= f.label :allergens, "Allergens", class: "form-label" %>
    <%= f.text_field :allergens, class: "form-control" %>
  </div>

  <div class="mb-4">
    <%= f.label :photo, "Photo", class: "form-label" %>
    <span class="text-muted small ms-1">(optional)</span>
    <%= f.file_field :photo, class: "form-control" %>
  </div>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "btn btn-primary rounded-4" %>
    <%= link_to "Cancel", recipes_path, class: "btn btn-outline-secondary rounded-4" %>
  </div>

<% end %>
