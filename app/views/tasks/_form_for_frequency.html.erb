<!-- Not done ! -->

<div class="container mt-4">
  <div class="row justify-content-left ms-2">
    <div class="col-md-12">
      <%= simple_form_for(task) do |f| %>

      <div class="mt-3">
          <%= f.input :name, placeholder: "Task name", label: false ,
              wrapper_html:{class: "mb-2"}%>
          <% if task.user_id %>
            <%= f.collection_select :user_id, @users.order(:name), :id, :name,
                { prompt: "Family member", selected: task.user_id },
                { class: 'form-select' }  %>
          <% else %>
            <%= f.collection_select :user_id, @users.order(:name), :id, :name,
                { prompt: "Family member" },
                { class: 'btn btn-primary rounded-2 fs-6' } %>
          <% end %>
          <%= f.input :description, placeholder: "Task description", label: false ,
              wrapper_html:{class: "mt-3"} %>
        </div>

        <div class="d-md-flex align-items-md-center gap-1">
          <div class="pe-2 col-md-6">
            <% if task.status && task.validation %>
              <%= f.input_field :status, as: :boolean,
                  label: "Done", disabled: true %>
            <% else %>
              <%= f.input :status, as: :boolean, label: "Done?",
                  wrapper_html:{class: "d-flex gap-1 col-4"}  %>
            <% end %>
            </div>
          <div class="pe-2 col-md-6">
            <%= f.input :task_points, collection: 1..10, label:"Reward points",
              wrapper_html:{class: "d-flex gap-3 align-items-center p-0"},
              selected: 1,
              label_html: {class: "p-0 m-0"}, prompt: "Number of points" %>
          </div>
        </div>
        <div class="d-md-flex gap-1">
          <div class="col-md-6">
            <%= f.input :start_date, as: :date, html5: true, label: "Start date",
                input_html: { value: Date.today} %>
          </div>
          <div class="col-md-6">
            <%= f.input :end_date, as: :date, html5: true, label: "End date",
                input_html: { value: Date.today } %>
          </div>
        </div>
        <div class="d-md-flex justify-content-md-between">
          <div class="col-md-6 pe-2">
            <!--<%= f.input :days,
              collection: ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
              as: :check_boxes,
              input_html: { multiple: true},
              label: "If repeating, on which days does the task occur?"%>-->
              <%= f.input :days, as: :check_boxes, input_html: { multiple: true},
                          collection: {
                            'Monday' => 1,
                            'Tuesday' => 2,
                            "Wednesday" => 3,
                            "Thursday" => 4,
                            "Friday" => 5,
                            "Saturday" => 6,
                            "Sunday" => 7
                          } %>
          </div>
          <div class="col-md-6">
            Frequency
            <!-- <%= f.input :montly_frequency, collection: 0..12, selected: 0 %> -->
            <%= f.input :weekly_flag, as: :boolean, label: 'Repeat weekly',
                        input_html: {checked: "unchecked"},
                        wrapper_html:{class: "m-0"}  %>
            <%= f.input :monthly_flag, as: :boolean, label: 'Repeat monthly',
                        input_html: {checked: "unchecked"},
                        wrapper_html:{class: "m-0"}  %>
          </div>
      </div>

      <div class="d-flex gap-3 mb-4 mt-2">
        <%= f.submit class: "btn btn-primary rounded-4" %>
        <%= link_to "Cancel", tasks_path, class: "btn btn-outline-secondary rounded-4" %>
      </div>
    <% end %>
    </div>
  </div>
</div>

