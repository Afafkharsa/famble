<%= simple_form_for(task) do |f| %>
  <div class="d-flex align-items-center">
    <div class="pe-2 text-secondary fw-bold">Done?</div>
    <% if task.status %>
      <%= f.input_field :status, as: :boolean, boolean_style: :inline, disabled: true %>
    <% else %>
      <%= f.input_field :status, as: :boolean, boolean_style: :inline, label:"done?" %>
    <% end %>
    <div class="pe-2 ps-4 text-secondary fw-bold">Rewards point</div>
      <%= f.input_field :task_points, label: false, collection: 1..10, selected: 1 , input_html: { class: 'text-secondary' } %>
    <div class="pe-2 ps-4 text-secondary fw-bold">Family member</div>
    <% if task.user %>
      <%=  f.collection_select :user_id, @users, :id, :name, { prompt: "Select someone", selected: @user }, { class: 'text-secondary' }  %>
    <% else %>
      <%= f.collection_select :user_id, @users, :id, :name, { prompt: "Select someone" }, { class: 'text-secondary' }  %>
    <% end %>
  </div>
  <div class="mt-3">
    <div class="pe-2 text-secondary fw-bold mb-2">Task parameters</div>
    <%= f.input :name, placeholder: "Task name", label: false , input_html: { class: 'text-secondary' }%>
    <%= f.input :description, placeholder: "Task description",
    label: false, input_html: { class: 'text-secondary' } %>

  </div>
  <div class="d-flex">
    <div class="pe-4">
      <%= f.input :start_date, as: :date, label: "Start date",
      input_html: { value: Date.today} %>

      <%= f.input :days,
        collection: %w[monday tuesday wednesday thursday friday saturday sunday],
         as: :check_boxes,
        input_html: { multiple: true},
        label: "If repeating, on which days does the task occur?"%>
    </div>
    <div>
      <%= f.input :end_date, as: :date , label: "End date", input_html: { value: Date.today } %>
      <%= f.input :montly_frequency, collection: 0..12, selected: 0 %>
    </div>
  </div>
  <div  class="d-flex">
  </div>
  <%= f.submit class: "btn btn-primary" %>
<% end %>
