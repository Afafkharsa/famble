<%= simple_form_for(task) do |f| %>
  <%= f.error_notification %>

  <div class="row g-3">
    <div class="col-md-8">
      <%= f.input :name, label: "Task name", placeholder: "e.g. Walk the dog" %>
    </div>
    <div class="col-md-4">
      <%= f.input :task_points, label: "Reward points",
          collection: 1..10, selected: task.task_points || 1,
          include_blank: false %>
    </div>
  </div>

  <%= f.input :user_id, label: "Assign to", collection: users,
      label_method: :name, value_method: :id,
      prompt: "Pick a family member",
      selected: task.user_id %>

  <%= f.input :description, label: "Description", as: :text,
      input_html: { rows: 3, placeholder: "Details, instructions, etc." } %>

  <hr class="my-4">
  <h6 class="text-uppercase text-muted small fw-bold mb-3">Schedule</h6>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.input :start_date, as: :date, html5: true, label: "Starts",
          input_html: { value: task.start_date || Date.today } %>
    </div>
    <div class="col-md-6">
      <%= f.input :end_date, as: :date, html5: true, label: "Ends",
          input_html: { value: task.end_date || Date.today } %>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-md-8">
      <%= f.input :days, label: "Repeat weekly on",
          collection: %w[monday tuesday wednesday thursday friday saturday sunday]
                        .map { |d| [d.first(3).capitalize, d] },
          as: :check_boxes,
          input_html: { multiple: true },
          item_wrapper_class: "form-check-inline" %>
    </div>
    <div class="col-md-4">
      <%= f.input :montly_frequency, label: "Repeat X times/year",
          collection: 0..12, selected: task.montly_frequency || 0,
          include_blank: false %>
    </div>
  </div>

  <% if task.persisted? %>
    <hr class="my-4">
    <%= f.input :status, as: :boolean, label: "Marked complete",
        disabled: task.validation %>
  <% end %>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit (task.persisted? ? "Save changes" : "Create task"), class: "btn btn-dark" %>
    <%= link_to "Cancel", tasks_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
