<%= simple_form_for(task) do |f| %>

  <%= f.input :name, placeholder: "Task name", label: "Name",
      wrapper_html: { class: "mb-3" } %>

  <%= f.collection_select :user_id, @users.order(:name), :id, :name,
      { prompt: "Select a family member", selected: task.user_id },
      { class: "form-select mb-3" } %>

  <%= f.input :description, placeholder: "Task description", label: "Description",
      wrapper_html: { class: "mb-3" } %>

  <div class="d-flex gap-3 mb-3">
    <div class="flex-fill">
      <%= f.input :task_points, collection: 1..10, label: "Reward points",
          selected: task.task_points || 1, prompt: "Points" %>
    </div>
    <div class="flex-fill">
      <% if task.status && task.validation %>
        <%= f.input :status, as: :boolean, label: "Done?", disabled: true %>
      <% else %>
        <%= f.input :status, as: :boolean, label: "Done?" %>
      <% end %>
    </div>
  </div>

  <div class="d-flex gap-3 mb-3">
    <div class="flex-fill">
      <%= f.input :start_date, as: :date, html5: true, label: "Start date",
          input_html: { value: task.start_date || Date.today } %>
    </div>
    <div class="flex-fill">
      <%= f.input :end_date, as: :date, html5: true, label: "End date",
          input_html: { value: task.end_date || Date.today } %>
    </div>
  </div>

  <%= f.input :days,
      collection: ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"],
      as: :check_boxes,
      input_html: { multiple: true },
      label: "Repeat on days" %>

  <%= f.input :montly_frequency, collection: 0..12, selected: task.montly_frequency || 0,
      label: "Monthly frequency" %>

  <div class="d-flex gap-2 mt-4">
    <%= f.submit class: "btn btn-primary rounded-4" %>
    <%= link_to "Cancel", tasks_path, class: "btn btn-outline-secondary rounded-4" %>
  </div>

<% end %>
