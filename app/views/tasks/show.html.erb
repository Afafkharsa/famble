<div class="container py-5 col-md-6">

  <div class="card base-card shadow-sm">
    <div class="card-body bg-white">
      <%= render "shared/back_link", url: root_path %>
      <div class="mb-3 mt-4">
        <h2 class="text-success d-flex gap-2 show-title align-items-end">

          <%= render "task_title", task: @task%>
        </h2>
      </div>

      <div class = "d-flex justify-content-start gap-3 mt-1 mb-4"
           data-controller="task-status"
           data-task-status-id-value="<%= @task.id %>">
        <div class="rounded-pill bg-primary-subtle text-secondary fw-bold px-3 py-2">
            <i class="fa-regular fa-user"></i>
            <%= @task.user.name %>
        </div>

        <%= render "task_completing", task: @task, user: @user  %>

        <div class="rounded-pill bg-primary-subtle text-secondary fw-bold px-3 py-2">
          <i class="fa-solid fa-award"></i>
          <%= @task.task_points > 0 ? "#{@task.task_points} points" : "#{@task.task_points} point"  %>
        </div>

      </div>

      <h5 class="fw-bold mt-4">Date</h5>

      <div class="mb-3 d-flex flex-column justify-content-start align-items-start">
        <div class="text-secondary fw-bold">
          <%= link_to calendars_path,
          style:"text-decoration: none; cursor: pointer; color: inherit;" do %>
            <i class="fa-solid fa-calendar-days text-secondary fw-bold" ></i>
          <% end %>
          <%= @task.start_date %>
          <% if @task.start_date != @task.end_date %>
            <i class="fa-solid fa-arrow-right"></i>
            <%= @task.end_date %>
          <% end %>
        </div>

        <div class="d-md-flex justify-content-between col-md-12">
          <div class="mt-1 col-md-3">
            <% if @task.days.any? || @task.montly_frequency > 0 %>
              <h5 class="fw-bold mt-4">Frequency</h5>
              <span class="text-secondary">Days:</span>
              <ul class="m-0 text-secondary ">
                <% @task.days.each do |day| %>
                  <li><%= day.capitalize %></li>
                <% end %>
              </ul>
              <span class="text-secondary"><%= @task.montly_frequency %> months / year</span>
            <% else %>
              No repeat
            <% end %>
          </div>

          <div class="mt-1 col-md-7">
            <h5 class="fw-bold mt-4">Description</h5>
            <div class="mt-2 mb-2 text-secondary ">
              <%= @task.description? ? @task.description : "No description" %>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

</div
