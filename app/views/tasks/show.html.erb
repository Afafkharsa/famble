<div class="container py-5 col-md-6">

  <div class="card shadow-sm">
    <div class="card-body bg-white">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><%= @task.name %></h2>
        <div class="text-secondary">
          ←
          <%= link_to "Back to tasks", tasks_path, class: "link-secondary link-underline-secondary" %>
        </div>
      </div>

      <div class = "d-flex justify-content-between mt-1 mb-4">
        <div class="rounded-pill bg-secondary-subtle text-secondary fw-bold  px-3 py-2 me-1">
            <i class="fa-regular fa-user"></i>
            <%= @task.user.name %>
        </div>
        <div class="rounded-pill bg-secondary-subtle text-secondary fw-bold px-3 py-2 me-1">
          <% if @task.status %>
            <button class="btn btn-primary btn-lg"
                    data-controller="task-status"
                    data-action="click->task-status#check">
              <i class="fa-regular fa-circle-check"></i> Done
            </button>
          <% else %>
            <i class="fa-regular fa-circle"></i> To do
          <% end %>
        </div>
        <div class="rounded-pill bg-secondary-subtle text-secondary fw-bold px-3 py-2 me-1">
          <i class="fa-solid fa-award"></i>
          <%= @task.task_points > 0 ? "#{@task.task_points} points" : "#{@task.task_points} point"  %>
        </div>
        <%= link_to edit_task_path(@task)  do %>
          <% if policy(Task).edit?  %>
            <div class="rounded-pill bg-success px-3 py-2 me-1">
              <i class="fa-regular fa-pen-to-square text-white fw-bold"></i>
            </div>
          <% end %>
        <% end %>
        <%= link_to task_path(@task),
          data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } do %>
          <% if policy(Task).destroy?  %>
            <div class="rounded-pill bg-danger px-3 py-2  me-1">
              <i class="fa-solid fa-eraser text-white fw-bold"></i>
            </div>
          <% end %>
        <% end %>
      </div>

      <h5 class="fw-bold mt-4">Date and frequency</h5>

      <div class="mb-3 d-flex flex-column justify-content-start align-items-start">
        <div class="text-secondary fw-bold">
          <%= link_to calendars_path,
          style:"text-decoration: none; cursor: pointer; color: inherit;" do %>
            <i class="fa-solid fa-calendar-days text-secondary fw-bold" ></i>
          <% end %>
          <%= @task.start_date %>
          <% if @task.start_date != @task.end_date %>
            <i class="fa-solid fa-arrow-right"></i>
            <%= @task.end_date %>
          <% end %>
        </div>
        <div class="text-secondary mt-1">
          <% if @task.days.any? || @task.montly_frequency > 0 %>
            Repeat :
            <ul class="m-0">
              <li>
                <% @task.days.each do |day| %>
                  <%= day.capitalize %>
                <% end %>
              </li>
              <li>
                <%= @task.montly_frequency %> months / year
              </li>
            </ul>
          <% else %>
            No repeat
          <% end %>
        </div>
      </div>

      <h5 class="fw-bold mt-4">Description</h5>
      <div class="mt-2 mb-2 text-secondary ">
        <%= @task.description? ? @task.description : "No description" %>
      </div>

    </div>
  </div>

</div
