<div class="container py-5">

  <div class="card shadow-sm">
    <div class="card-body">

      <h1 class="card-title "><%= @task.name %></h1>
      <h3 class="card-title mb-4"><%= @task.user.name %></h3>

      <div class = "d-flex">
        <p class="mb-3">
          <span class="badge rounded-pill bg-secondary-subtle text-secondary px-3 py-2 me-1">
            <%= @task.start_date %> &nbsp;-&nbsp;
            <%= @task.end_date %>
          </span>
        </p>

        <p class="mb-3">
          <span class="badge rounded-pill bg-secondary-subtle text-secondary px-3 py-2 me-1">
            <%= @task.status ? "Done" : "To do" %>
          </span>
        </p>

        <p class="mb-3">
          <span class="badge rounded-pill bg-secondary-subtle text-secondary px-3 py-2 me-1">
              <i class="fa-solid fa-award"></i>
              <%= @task.task_points > 0 ? "#{@task.task_points} points" : "#{@task.task_points} point"  %>
          </span>
        </p>
      </div>

      <h3 class="h5 fw-bold text-secondary mt-4">Description</h3>
      <div class="mt-2 mb-5">
        <%= @task.description? ? @task.description : "No description" %>
      </div>

      <div class="d-flex gap-2">
        <%= link_to "Back to tasks", tasks_path, class: "btn btn-outline-secondary" %>
      </div>

    </div>
  </div>

</div
