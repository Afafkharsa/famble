<span class="recipe-card-name flex-grow-1"><%= task.name %></span>

<% if policy(task).edit? || policy(task).new? || policy(task).destroy? %>
  <div class="dropdown reward-three-dot">
    <button data-bs-toggle="dropdown" aria-expanded="false" aria-label="Options">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="opacity: 0.4;">
        <circle cx="8" cy="3" r="1.2"/>
        <circle cx="8" cy="8" r="1.2"/>
        <circle cx="8" cy="13" r="1.2"/>
      </svg>
    </button>
    <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="font-size: 12px; min-width: 130px; border-radius: 10px;">
      <% if policy(task).edit? %>
        <li>
          <%= link_to edit_task_path(task), class: "dropdown-item d-flex align-items-center gap-2" do %>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.5;">
              <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>
            </svg>
            Edit
          <% end %>
        </li>
      <% end %>
      <% if policy(task).new? %>
        <li>
          <%= link_to new_task_path(
                name: task.name,
                description: task.description,
                task_points: task.task_points,
                days: task.days,
                montly_frequency: task.montly_frequency,
                user: task.user
              ), class: "dropdown-item d-flex align-items-center gap-2" do %>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity: 0.5;">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
            Duplicate
          <% end %>
        </li>
      <% end %>
      <% if policy(task).destroy? %>
        <li>
          <%= link_to task_path(task),
              data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
              class: "dropdown-item d-flex align-items-center gap-2 text-danger" do %>
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
            </svg>
            Delete
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="rounded-circle overflow-hidden flex-shrink-0 d-flex align-items-center justify-content-center"
     style="width:22px;height:22px;background:<%= task.user.color %>;">
  <% if task.user.photo.attached? %>
    <%= image_tag task.user.photo, style: "width:100%;height:100%;object-fit:cover;" %>
  <% else %>
    <span style="font-size:8px;font-weight:700;color:rgba(14,0,0,0.5);">
      <%= (task.user.name || task.user.email).split(' ').map { |w| w[0].upcase }.first(2).join %>
    </span>
  <% end %>
</div>
