<div class="container mt-4">
  <% if @user_tasks.any? %>
    <h2 class="mt-3">My tasks</h2>
    <div class="row g-4">
      <% @user_tasks.each do |task| %>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body">
              <h5 class="card-title text-secondary">
                <%= task.name %>
              </h5>

              <div class = "d-flex mb-0 mt-3 rounded-2 bg-secondary-subtle">
                <% if task.start_date = task.end_date  %>
                  <div class="col-md-4 badge text-secondary px-3 py-2 me-1">
                    <%= task.start_date %>
                  </div>
                <% else %>
                  <div class="col-md-4 badge text-secondary px-3 py-2 me-1">
                    <%= task.start_date %>
                  </div>
                  <div class="col-md-4 badge text-secondary px-3 py-2 me-1">
                    <%= task.end_date %>
                  </div>
                <% end %>
                <div class="col-md-4 badge text-secondary px-3 py-2 me-1">
                  <% if task.status? %>
                    <i class="fa-regular fa-circle-check"></i> Done
                  <% else %>
                    <i class="fa-regular fa-circle"></i> To do
                  <% end %>
                </div>
                <div class="col-md-4 badge text-secondary px-3 py-2 me-1">
                    <i class="fa-solid fa-award"></i>
                    <%= task.task_points > 0 ? "#{task.task_points} points" : "#{task.task_points} point"  %>
                </div>
              </div>

              <h5 class="h5 fw-bold text-secondary mt-4">Description</h5>
              <div class="mt-2">
                <%= task.description? ? task.description : "No description" %>
              </div>

              <div  class="d-flex justify-content-between mt-3">
                <%= link_to "View task", task_path(task),
                  class: "btn btn-outline-secondary btn-sm rounded-pill" %>
                <%= link_to "Edit task", edit_task_path(task),
                  class: "btn btn-outline-warning btn-sm rounded-pill" %>
                <%= link_to "Delete task", task_path(task),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                  class: "btn btn-outline-danger btn-sm rounded-pill" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @role = "parent" &&  @family_tasks.any? %>
    <h2 class="mt-3">Family tasks</h2>
    <div class="row g-4">
      <% @family_tasks.each do |task| %>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body">
              <h5 class="card-title text-secondary">
                <%= task.name %> - <%= task.user.name %>
              </h5>
              <div class = "d-flex mb-0 mt-3 rounded-2 bg-secondary-subtle">
                <% if task.start_date = task.end_date  %>
                  <div class="col-md-4 badge text-secondary px-3 py-2 me-1">
                    <%= task.start_date %>
                  </div>
                <% else %>
                  <div class="col-md-4 badge text-secondary px-3 py-2 me-1">
                    <%= task.start_date %>
                  </div>
                  <div class="col-md-4 badge text-secondary px-3 py-2 me-1">
                    <%= task.end_date %>
                  </div>
                <% end %>
                <div class="col-md-4 badge text-secondary px-3 py-2 me-1">
                  <% if task.status? %>
                    <i class="fa-regular fa-circle-check"></i> Done
                  <% else %>
                    <i class="fa-regular fa-circle"></i> To do
                  <% end %>
                </div>
                <div class="col-md-4 badge text-secondary px-3 py-2 me-1">
                    <i class="fa-solid fa-award"></i>
                    <%= task.task_points > 0 ? "#{task.task_points} points" : "#{task.task_points} point"  %>
                </div>
              </div>
              <h5 class="h5 fw-bold text-secondary mt-4">Description</h5>
              <div class="mt-2">
                <%= task.description? ? task.description : "No description" %>
              </div>
              <div  class="d-flex justify-content-between mt-3">
                <%= link_to "View task", task_path(task),
                  class: "btn btn-outline-secondary btn-sm rounded-pill" %>
                <%= link_to "Edit task", edit_task_path(task),
                  class: "btn btn-outline-warning btn-sm rounded-pill" %>
                <%= link_to "Delete task", task_path(task),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                  class: "btn btn-outline-danger btn-sm rounded-pill" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <% end %>
  </div>
</div>
