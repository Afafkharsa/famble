<div class="tasks-page" data-controller="member-filter">

  <div class="container py-4 pb-5">
    <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
      <div>
        <h1 class="h3 fw-bold mb-1">Family tasks</h1>
        <p class="text-muted small mb-0">Who's doing what this week</p>
      </div>
      <% if current_user.parent? %>
        <div class="d-flex gap-2">
          <%= link_to "Library", task_templates_path, class: "btn btn-outline-dark" %>
          <%= link_to "+ Add task", new_task_path, class: "btn btn-dark" %>
        </div>
      <% end %>
    </div>

    <%# Member filter — click an avatar to hide/show that member's column %>
    <div class="d-flex flex-wrap gap-2 mb-3">
      <% current_user.family.users.each do |member| %>
        <button type="button"
                class="btn btn-sm rounded-pill d-inline-flex align-items-center gap-2 filter-chip is-active"
                style="background: <%= member.avatar_color %>; border: none;"
                data-action="click->member-filter#toggle"
                data-member-filter-target="chip"
                data-member-id="<%= member.id %>"
                title="Click to hide <%= member.display_name %>">
          <span class="rounded-circle bg-white d-inline-flex align-items-center justify-content-center fw-bold overflow-hidden"
                style="width: 22px; height: 22px; font-size: 0.7rem;">
            <% if member.photo.attached? %>
              <%= image_tag member.photo, style: "width: 100%; height: 100%; object-fit: cover;" %>
            <% else %>
              <%= member.initials %>
            <% end %>
          </span>
          <span class="small fw-bold"><%= member.display_name %></span>
        </button>
      <% end %>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-3">
      <% current_user.family.users.each do |member| %>
        <% member_tasks = member.tasks.order(:end_date, :start_date) %>
        <% todo_count = member_tasks.reject(&:validation).count %>
        <% done_count = member_tasks.select(&:validation).count %>

        <div class="col" data-member-filter-target="column" data-member-id="<%= member.id %>">
          <div class="card member-card border-0 shadow-sm rounded-5 overflow-hidden">
            <%# Member header %>
            <div class="member-head text-center p-3" style="background: <%= member.avatar_color %>">
              <% if member.parent? %>
                <div class="crown" title="Parent">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                       stroke="rgba(14,0,0,0.25)" stroke-width="1.5"
                       stroke-linecap="round" stroke-linejoin="round">
                    <path d="M2 20h20"/>
                    <path d="M4 20l1-11 5 5 3-7 3 7 5-5 1 11"/>
                    <circle cx="4" cy="7" r="1.2"/>
                    <circle cx="12" cy="4" r="1.2"/>
                    <circle cx="20" cy="7" r="1.2"/>
                  </svg>
                </div>
              <% end %>

              <div class="member-head__avatar mx-auto mb-2">
                <% if member.photo.attached? %>
                  <%= image_tag member.photo, style: "width: 100%; height: 100%; object-fit: cover;" %>
                <% else %>
                  <%= member.initials %>
                <% end %>
              </div>
              <p class="fw-bold mb-0"><%= member.display_name %></p>

              <div class="d-flex justify-content-center gap-1 flex-wrap mt-2">
                <span class="badge rounded-pill bg-white text-dark fw-bold"><%= todo_count %> to do</span>
                <span class="badge rounded-pill bg-light text-secondary fw-bold"><%= done_count %> done</span>
              </div>
            </div>

            <%# Task list + parent-only add footer %>
            <ul class="list-group list-group-flush">
              <% member_tasks.each do |task| %>
                <% can_toggle = current_user.parent? || (task.user == current_user && !task.validation) %>
                <li class="list-group-item border-0 border-top p-3">
                  <% if can_toggle %>
                    <button type="button" class="btn p-0 border-0 bg-transparent text-start w-100"
                            data-controller="task-status"
                            data-task-status-id-value="<%= task.id %>"
                            data-task-status-current-value="<%= task.status %>"
                            data-action="click->task-status#toggle"
                            title="<%= task.status ? 'Uncheck' : 'Mark complete' %>">
                      <div class="d-flex align-items-start gap-2 mb-2 pe-4">
                        <% if task.status %>
                          <i class="bi bi-check-circle-fill text-success flex-shrink-0" style="font-size: 1.6rem;"></i>
                        <% else %>
                          <i class="bi bi-circle text-secondary flex-shrink-0" style="font-size: 1.6rem;"></i>
                        <% end %>
                        <div class="flex-grow-1 min-w-0">
                          <p class="fw-bold mb-0 small"><%= task.name %></p>
                          <p class="text-muted mb-0" style="font-size: 0.7rem;">
                            <%= task.task_points %> pts
                            <% if task.end_date %>&middot; <%= task.end_date.strftime("%b %-d") %><% end %>
                          </p>
                        </div>
                      </div>
                    </button>
                  <% else %>
                    <div class="d-flex align-items-start gap-2 mb-2 pe-4">
                      <span class="flex-shrink-0 d-inline-flex align-items-center"
                            title="<%= task.status_label %>">
                        <i class="bi bi-check-circle-fill text-success" style="font-size: 1.6rem;"></i>
                      </span>
                      <div class="flex-grow-1 min-w-0">
                        <p class="fw-bold mb-0 small"><%= task.name %></p>
                        <p class="text-muted mb-0" style="font-size: 0.7rem;">
                          <%= task.task_points %> pts
                          <% if task.end_date %>&middot; <%= task.end_date.strftime("%b %-d") %><% end %>
                        </p>
                      </div>
                    </div>
                  <% end %>

                  <% if policy(task).edit? || policy(task).destroy? %>
                    <div class="dropdown item-actions">
                      <button type="button" class="btn btn-sm btn-light rounded-circle p-0 lh-1"
                              style="width: 26px; height: 26px;"
                              data-bs-toggle="dropdown" aria-expanded="false"
                              title="More actions">
                        <i class="bi bi-three-dots"></i>
                      </button>
                      <ul class="dropdown-menu dropdown-menu-end small">
                        <% if policy(task).edit? %>
                          <li>
                            <%= link_to edit_task_path(task), class: "dropdown-item" do %>
                              <i class="bi bi-pencil-square me-2"></i>Edit
                            <% end %>
                          </li>
                        <% end %>
                        <% if policy(task).destroy? %>
                          <li>
                            <%= link_to task_path(task),
                                data: { turbo_method: :delete, turbo_confirm: "Delete this task?" },
                                class: "dropdown-item text-danger" do %>
                              <i class="bi bi-trash me-2"></i>Delete
                            <% end %>
                          </li>
                        <% end %>
                      </ul>
                    </div>
                  <% end %>

                  <% if current_user.parent? && task.status && !task.validation %>
                    <div class="d-flex">
                      <button type="button" class="btn btn-success btn-sm flex-grow-1 fw-bold"
                              data-controller="task-status"
                              data-task-status-id-value="<%= task.id %>"
                              data-task-status-target="approval"
                              data-action="click->task-status#validate">
                        Validate
                      </button>
                    </div>
                  <% end %>
                </li>
              <% end %>

              <% if current_user.parent? %>
                <li class="list-group-item border-0 border-top p-0">
                  <%= link_to new_task_path(user: member.id),
                      class: "d-flex align-items-center justify-content-center gap-2 p-2 text-muted text-decoration-none small" do %>
                    <span class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center"
                          style="width: 26px; height: 26px;">+</span>
                    Add task
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# Mobile bottom tab bar %>
  <nav class="tab-bar d-md-none bg-white border-top shadow-sm">
    <%= link_to root_path, class: "tab-bar__item" do %>
      <i class="bi bi-house"></i><span>Home</span>
    <% end %>
    <%= link_to tasks_path, class: "tab-bar__item is-active" do %>
      <i class="bi bi-check2-square"></i><span>Tasks</span>
    <% end %>
    <%= link_to meal_plans_path, class: "tab-bar__item" do %>
      <i class="bi bi-egg-fried"></i><span>Meals</span>
    <% end %>
    <%= link_to rewards_path, class: "tab-bar__item" do %>
      <i class="bi bi-star"></i><span>Rewards</span>
    <% end %>
    <%= link_to calendars_path, class: "tab-bar__item" do %>
      <i class="bi bi-calendar3"></i><span>Calendar</span>
    <% end %>
  </nav>
</div>
