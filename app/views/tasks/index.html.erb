<div class="container mt-4">

  <h2 class="mt-3 d-flex">
    My tasks
    <% if @user.role == "parent" %>
      <%= link_to new_task_path(:user => @user) do %>
        <% if policy(Task).new? %>
          <div style= "text-decoration: none; cursor: pointer; color: inherit;">
            <i class="fa-solid fa-plus text-body-secondary fs-4 ps-2"></i>
          </div>
        <% end %>
      <% end %>
      <%= link_to task_templates_path do %>
        <div style= "text-decoration: none; cursor: pointer; color: inherit;">
          <i class="fa-regular fa-file-lines text-body-secondary fs-4 ps-2"></i>
        </div>
      <% end %>
    <% end %>
  </h2>
  <% if @user_tasks.any? %>
    <div class="row g-4">
      <% @user_tasks.each do |task| %>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm h-100 bg-white">
            <div class="card-body">
              <h5 class="card-title text-secondary">
                <%= task.name %>
              </h5>

              <div class = "d-flex mb-0 mt-3 rounded-2 bg-secondary-subtle justify-content-between">
                <div class="badge text-secondary py-2">
                  <i class="fa-solid fa-calendar-days"></i>
                  <%= task.start_date %>
                  <% if task.start_date != task.end_date %>
                    <i class="fa-solid fa-arrow-right"></i>
                    <%= task.end_date %>
                  <% end %>
                </div>
                <div class="badge text-secondary py-2">
                  <% if task.status? %>
                    <i class="fa-regular fa-circle-check"></i> Done
                  <% else %>
                    <i class="fa-regular fa-circle"></i> To do
                  <% end %>
                </div>
                <div class="badge text-secondary py-2">
                    <i class="fa-solid fa-award"></i>
                    <%= task.task_points > 1 ? "#{task.task_points} pts" : "#{task.task_points} pt"  %>
                </div>
              </div>

              <div class="mt-2 text-secondary ps-2">
                <%= task.description? ? task.description : "No description" %>
              </div>

              <div  class="d-flex justify-content-between mt-3">
                <%= link_to "View task", task_path(task),
                  class: "btn btn-outline-secondary btn-sm rounded-pill" %>
                <%= link_to "Edit task", edit_task_path(task),
                  class: "btn btn-outline-warning btn-sm rounded-pill" %>
                <%= link_to "Delete task", task_path(task),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                  class: "btn btn-outline-danger btn-sm rounded-pill" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 bg-white">
          <div class="card-body">
            <h5 class="card-title text-secondary">
              You have no tasks assigned yet
            </h5>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <% if @user.role = "parent" %>
    <h2 class="mt-3 d-flex">
      Family tasks
      <%= link_to new_task_path() do %>
        <div style= "text-decoration: none; cursor: pointer; color: inherit;">
          <i class="fa-solid fa-plus text-body-secondary fs-4 ps-2"></i>
        </div>
      <% end %>
      <%= link_to task_templates_path do %>
        <div style= "text-decoration: none; cursor: pointer; color: inherit;">
          <i class="fa-regular fa-file-lines text-body-secondary fs-4 ps-2"></i>
        </div>
      <% end %>
    </h2>
    <div class="row g-4">
      <% if @family_tasks.any?  %>
        <% @family_tasks.each do |task| %>
          <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 bg-white">
              <div class="card-body">
                <h5 class="card-title text-secondary">
                  <%= task.name %>
                </h5>

                <div class = "d-flex mb-0 mt-3 rounded-2 bg-secondary-subtle justify-content-between">
                  <div class="badge text-secondary py-2">
                    <i class="fa-solid fa-calendar-days"></i>
                    <%= task.start_date %>
                    <% if task.start_date != task.end_date %>
                      <i class="fa-solid fa-arrow-right"></i>
                      <%= task.end_date %>
                    <% end %>
                  </div>
                  <div class=" badge text-secondary py-2">
                    <% if task.status? %>
                      <i class="fa-regular fa-circle-check"></i> Done
                    <% else %>
                      <i class="fa-regular fa-circle"></i> To do
                    <% end %>
                  </div>
                  <div class="badge text-secondary py-2">
                      <i class="fa-solid fa-award"></i>
                      <%= task.task_points > 1 ? "#{task.task_points} pts" : "#{task.task_points} pt"  %>
                  </div>
                </div>
                <div class="mt-2 text-secondary ps-2">
                  Assigned to: <%= task.user.name %>
                </div>
                <div  class="d-flex justify-content-between mt-3">
                  <%= link_to "View task", task_path(task),
                    class: "btn btn-outline-secondary btn-sm rounded-pill" %>
                  <%= link_to "Edit task", edit_task_path(task),
                    class: "btn btn-outline-warning btn-sm rounded-pill" %>
                  <%= link_to "Delete task", task_path(task),
                    data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                    class: "btn btn-outline-danger btn-sm rounded-pill" %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
