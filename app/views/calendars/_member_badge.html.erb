<span class="d-inline-flex align-items-center gap-1 flex-shrink-0"
      title="<%= member.display_name %>">
  <span class="rounded-circle d-inline-flex align-items-center justify-content-center fw-bold overflow-hidden"
        style="width: 22px; height: 22px; background: <%= member.avatar_color %>; font-size: 0.65rem;">
    <% if member.photo.attached? %>
      <%= image_tag member.photo, style: "width: 100%; height: 100%; object-fit: cover;" %>
    <% else %>
      <%= member.initials %>
    <% end %>
  </span>
</span>
