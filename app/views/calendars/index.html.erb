<div class="container mt-3">
  <%= link_to root_path, class: "back-link" do %><i class="bi bi-chevron-left"></i> Back<% end %>

  <div class="d-flex align-items-center justify-content-between mb-3">
    <div class="d-flex align-items-center gap-3">
      <h1 class="fw-bold mb-0">Calendar</h1>
      <% if policy(Event).new? %>
        <%= link_to new_event_path, class: "text-decoration-none text-secondary" do %>
          <i class="bi bi-plus-circle fs-4"></i>
        <% end %>
      <% end %>
    </div>
    <%= form_with url: calendars_path, method: :get, local: true, class: "d-flex gap-2 align-items-center" do |f| %>
      <%= f.select :month,
          (1..12).map { |m| [I18n.l(Date.new(2026, m), format: '%B'), m] },
          { selected: @start_date.month },
          { class: "cal-jump-select", onchange: "this.form.requestSubmit()" } %>
      <%= f.select :year,
          (Date.today.year - 2..Date.today.year + 5).to_a,
          { selected: @start_date.year },
          { class: "cal-jump-select", onchange: "this.form.requestSubmit()" } %>
    <% end %>
  </div>

  <%= month_calendar(start_date: @start_date, events: []) do |date, items| %>
    <%= link_to day_detail_calendars_path(date: date), data: { turbo_frame: "modal" }, class: "d-block text-decoration-none h-100" do %>
      <div class="cal__num"><%= date.day %></div>

      <% day_events = @events.select { |event| event.start_time.to_date == date } %>
      <% day_tasks  = @tasks.select  { |task|  task.end_date.to_date    == date } %>
      <% day_meals  = @meal_plans.select { |meal| meal.day == date } %>
      <% total_recipes = day_meals.sum { |meal| meal.recipe_meal_plans.count } %>

      <div class="cal__events">
        <% if day_tasks.any? %>
          <span class="cal__event cal__event--task">
            <span class="cal__dot"></span>
            <%= day_tasks.count %> Task<%= day_tasks.count > 1 ? 's' : '' %>
          </span>
        <% end %>
        <% if day_events.any? %>
          <span class="cal__event cal__event--event">
            <span class="cal__dot"></span>
            <%= day_events.count %> Event<%= day_events.count > 1 ? 's' : '' %>
          </span>
        <% end %>
        <% if day_meals.any? %>
          <span class="cal__event cal__event--meal">
            <span class="cal__dot"></span>
            <%= total_recipes %> Meal<%= total_recipes > 1 ? 's' : '' %>
          </span>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= turbo_frame_tag "modal" %>
</div>
