<% unless current_user %>
  <%= content_for(:navbar_class, "navbar-home") %>
<% end %>

<% if current_user && current_user.role %>
  <div class="container d-flex flex-column min-vh-100 py-4" style="min-height: calc(100vh - 56px);">

    <!-- Top main button -->
    <div class="row mb-4">
      <div class="col-12">
        <%= link_to meal_plans_path, class: "btn-date w-100" do %>
          <p class="mb-2">
            <strong><%= Date.today.strftime("%A, %B %d") %></strong>
          </p>
        <% end %>
      </div>
    </div>

    <!-- Row 2: 3 buttons -->
    <div class="row g-4 mb-3" style="flex: 1;">

      <div class="col-md-4 d-flex">
        <%= link_to recipes_path, class: "dashboard-button text-decoration-none", style: "background-image: url(#{asset_path('recipes_button.jpg')});" do %>
          <div class="button-title">
            Recipes
          </div>
        <% end %>
      </div>

      <div class="col-md-4 d-flex">
        <%= link_to tasks_path, class: "dashboard-button text-decoration-none", style: "background-image: url(#{asset_path('tasks_button.jpg')});" do %>
          <div class="button-title">
            Tasks
          </div>
        <% end %>
      </div>

      <div class="col-md-4 d-flex">
        <%= link_to rewards_path, class: "dashboard-button text-decoration-none", style: "background-image: url(#{asset_path('rewards_button.jpg')});" do %>
          <div class="button-title">
            Rewards
          </div>
        <% end %>
      </div>
    </div>

    <!-- Row 3: 3 buttons -->
    <div class="row g-4 mb-3" style="flex: 1;">

      <div class="col-md-4 d-flex">
        <%= link_to families_path, class: "dashboard-button text-decoration-none", style: "background-image: url(#{asset_path('family_button.jpg')});" do %>
          <div class="button-title">
            Family
          </div>
        <% end %>
      </div>

      <div class="col-md-4 d-flex">
        <%= link_to calendars_path, class: "dashboard-button text-decoration-none", style: "background-image: url(#{asset_path('calendar_button.jpg')});" do %>
          <div class="button-title">
            Calendar
          </div>
        <% end %>
      </div>

      <div class="col-md-4 d-flex">
        <%= link_to chats_path, class: "dashboard-button text-decoration-none", style: "background-image: url(#{asset_path('chatbot_button.jpg')});" do %>
          <div class="button-title">
            Chatbot
          </div>
        <% end %>
      </div>
    </div>

  </div>
<% elsif current_user && !current_user.role %>
  <div class="container py-5">
    <div class="row g-4 mb-4">
      <div class="col-md-8">
        Your subscription to <%= current_user.family.name %> is waiting for validation.
      </div>
    </div>
  </div>
<% else %>
  <!-- HERO / BANNER -->
  <div class="banner">
    <div class="banner-content text-center">
      <h1>Bring harmony to your family life</h1>
      <p>Meals, tasks, and rewards — all organized in one place</p>
      <div class="d-flex flex-wrap justify-content-center gap-2">
        <%= link_to "Get Started", new_user_registration_path, class: "btn btn-primary btn-lg fs-6" %>
        <%= link_to "Log in", new_user_session_path, class: "btn btn-info btn-lg fs-6" %>
      </div>
    </div>
  </div>
<% end %>
