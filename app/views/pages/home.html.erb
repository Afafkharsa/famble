<% unless current_user %>
  <%= content_for(:navbar_class, "navbar-home") %>
<% end %>

<% if current_user && current_user.role %>
  <div class="dashboard-shell container my-4 p-4">

  <%# --- Welcome card --- %>
  <section class="bg-white rounded-4 p-4 mb-3 border border-subtle">
    <div class="d-flex justify-content-between align-items-start mb-3 gap-3">
      <div>
        <p class="text-muted small mb-1"><%= Date.today.strftime("%A, %-d %B") %></p>
        <h1 class="fs-2 fw-medium mb-1">The <%= @family.name %> family</h1>
        <p class="text-muted small mb-0"><%= @members.size %> members</p>
      </div>
    </div>

    <div class="row g-2">
      <% @members.each do |member| %>
        <div class="col-6 col-md-3">
          <div class="member-chip d-flex align-items-center gap-2 p-2 rounded-3"
               style="background: <%= member.avatar_color %>;">
            <span class="member-chip__avatar rounded-circle bg-white d-flex align-items-center justify-content-center fw-medium">
              <%= member.initials %>
            </span>
            <div class="min-w-0">
              <p class="mb-0 small fw-medium"><%= member.display_name %></p>
              <p class="mb-0 text-muted" style="font-size: 0.7rem;">
                <%= member.role.presence || "member" %>
              </p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<%# --- Stat strip --- %>
<div class="row g-2 mb-3 stat-strip">
  <div class="col-6 col-md-3">
    <div class="stat-card rounded-4 p-3 h-100" style="background: #BDE3C3;">
      <p class="small text-muted mb-1">Tasks today</p>
      <div class="fs-4 fw-medium"><%= @tasks_today_done %> of <%= @tasks_today.size %></div>
      <p class="text-muted mb-0" style="font-size: 0.7rem;">across the family</p>
    </div>
  </div>

  <div class="col-6 col-md-3">
    <div class="stat-card rounded-4 p-3 h-100" style="background: #F8F7BA;">
      <p class="small text-muted mb-1">Meals planned</p>
      <div class="fs-4 fw-medium">
        <%= @meals_today_count %>
        <span class="text-muted fw-normal" style="font-size: 0.7rem;">today</span>
      </div>
      <p class="text-muted mb-0" style="font-size: 0.7rem;">
        <%= @todays_meal_plan ? "planned for today" : "nothing planned yet" %>
      </p>
    </div>
  </div>

  <div class="col-6 col-md-3">
    <div class="stat-card rounded-4 p-3 h-100" style="background: #A3CCDA;">
      <p class="small text-muted mb-1">Events this week</p>
      <div class="fs-4 fw-medium">
        <%= @week_events.size %>
        <% if @next_event %>
          <span class="text-muted fw-normal" style="font-size: 0.7rem;">
            next <%= @next_event.start_time.strftime("%-l:%M %p") %>
          </span>
        <% end %>
      </div>
      <p class="text-muted mb-0" style="font-size: 0.7rem;">
        <%= @next_event&.title || "nothing scheduled" %>
      </p>
    </div>
  </div>

  <div class="col-6 col-md-3">
    <div class="stat-card rounded-4 p-3 h-100" style="background: #F5D2D2;">
      <p class="small text-muted mb-1">Family points</p>
      <div class="fs-4 fw-medium">
        <%= @family_points %>
        <span class="text-muted fw-normal" style="font-size: 0.7rem;">this week</span>
      </div>
      <p class="text-muted mb-0" style="font-size: 0.7rem;">across all members</p>
    </div>
  </div>
</div>
<%# --- Today's menu + Everyone's tasks --- %>
<div class="row g-3 mb-3">

  <%# Today's menu %>
  <div class="col-md-6">
    <section class="bg-white rounded-4 p-3 h-100 border border-subtle">
      <h2 class="fs-6 fw-medium mb-3">Today's menu</h2>
      <% if @todays_recipe_meal_plans.any? %>
        <div class="d-flex flex-column gap-2">
          <% @todays_recipe_meal_plans.each do |rmp| %>
            <% bg = { "Breakfast" => "#F8F7BA", "Lunch" => "#BDE3C3", "Dinner" => "#F5D2D2" }[rmp.meal_type] || "#F4F4F4" %>
            <div class="menu-row d-flex align-items-center gap-2 p-2 rounded-3" style="background: <%= bg %>;">
              <span class="menu-row__badge rounded-3 bg-white d-flex align-items-center justify-content-center fw-medium">
                <%= rmp.meal_type.to_s.first %>
              </span>
              <div class="flex-grow-1 min-w-0">
                <p class="mb-0 text-muted" style="font-size: 0.7rem;"><%= rmp.meal_type %></p>
                <p class="mb-0 small fw-medium text-truncate"><%= rmp.recipe.name %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted small mb-0">No meals planned for today.</p>
      <% end %>
    </section>
  </div>

  <%# Everyone's tasks %>
  <div class="col-md-6">
    <section class="bg-white rounded-4 p-3 h-100 border border-subtle">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fs-6 fw-medium mb-0">Everyone's tasks</h2>
        <span class="text-muted" style="font-size: 0.7rem;">
          <%= @tasks_today_done %> of <%= @tasks_today.size %> done
        </span>
      </div>

      <% if @tasks_today.any? %>
        <div class="d-flex flex-column gap-1">
          <% @tasks_today.includes(:user).order(validation: :desc, start_date: :asc).each do |task| %>
            <div class="task-row d-flex align-items-center gap-2 p-2 rounded-3">
              <% if task.validation %>
                <span class="task-row__check d-flex align-items-center justify-content-center rounded bg-dark text-white">&#10003;</span>
              <% else %>
                <span class="task-row__check rounded border border-dark bg-white"></span>
              <% end %>

              <span class="task-row__avatar rounded-circle d-flex align-items-center justify-content-center fw-medium"
                    style="background: <%= task.user.avatar_color %>;">
                <%= task.user.initials %>
              </span>

              <span class="flex-grow-1 small text-truncate <%= 'text-decoration-line-through text-muted' if task.validation %>">
                <%= task.name %>
              </span>

              <span class="badge bg-light text-muted fw-normal">+<%= task.task_points %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted small mb-0">No tasks scheduled for today.</p>
      <% end %>
    </section>
  </div>
</div>
<section class="bg-white rounded-4 p-3 mb-3 border border-subtle">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fs-6 fw-medium mb-0">Family calendar</h2>
    <span class="text-muted" style="font-size: 0.7rem;">
      <%= Time.current.beginning_of_week.strftime("%-d") %>
      &ndash;
      <%= Time.current.end_of_week.strftime("%-d %b") %>
      &middot; <%= @week_events.size %> events
    </span>
  </div>

  <% if @week_events.any? %>
    <div class="row g-2">
      <% @week_events.each do |event| %>
        <div class="col-md-6">
          <div class="event-row d-flex align-items-center gap-3 p-2 rounded-3"
               style="background: <%= event.user.avatar_color %>33;">
            <div class="event-row__date text-center">
              <p class="mb-0 text-muted" style="font-size: 0.65rem;">
                <%= event.start_time.strftime("%a") %>
              </p>
              <p class="mb-0 fw-medium"><%= event.start_time.strftime("%-d") %></p>
            </div>

            <div class="flex-grow-1 min-w-0 ps-2 border-start">
              <p class="mb-0 small fw-medium text-truncate"><%= event.title %></p>
              <p class="mb-0 text-muted" style="font-size: 0.7rem;">
                <%= event.start_time.strftime("%-l:%M %p") %>
              </p>
            </div>

            <span class="event-row__avatar rounded-circle border border-white d-flex align-items-center justify-content-center fw-medium"
                  style="background: <%= event.user.avatar_color %>;">
              <%= event.user.initials %>
            </span>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted small mb-0">No events scheduled this week.</p>
  <% end %>
</section>
  <%# --- Rewards leaderboard (compact summary) --- %>
  <section class="bg-white rounded-4 p-3 border border-subtle">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
      <div>
        <h2 class="fs-6 fw-medium mb-0">Rewards leaderboard</h2>
        <p class="text-muted mb-0" style="font-size: 0.75rem;">
          Summary of this cycle's points
        </p>
      </div>
      <%= link_to "Redeem points", rewards_path,
          class: "btn btn-sm btn-danger fw-medium" %>
    </div>

    <div class="row g-3">
      <% @leaderboard.each do |row| %>
        <% member   = row[:member] %>
        <% earned   = row[:earned] %>
        <% to_spend = row[:to_spend] %>
        <% pct = @top_points.zero? ? 0 : ((earned.to_f / @top_points) * 100).round %>
        <div class="col-6 col-md-3">
          <div class="d-flex align-items-center gap-2 mb-2">
            <span class="leaderboard__avatar rounded-circle d-flex align-items-center justify-content-center fw-medium"
                  style="background: <%= member.avatar_color %>;">
              <%= member.initials %>
            </span>
            <div class="min-w-0">
              <p class="mb-0 small fw-medium text-truncate"><%= member.display_name %></p>
              <div class="d-flex gap-1 flex-wrap">
                <span class="badge bg-light text-muted fw-normal"><%= to_spend %> to spend</span>
                <span class="badge bg-light text-muted fw-normal"><%= earned %> earned</span>
              </div>
            </div>
          </div>

          <div class="leaderboard__bar rounded-pill overflow-hidden">
            <div class="leaderboard__bar-fill"
                 style="width: <%= pct %>%; background: <%= member.avatar_color %>;"></div>
          </div>
        </div>
      <% end %>
    </div>
  </section>
</div>
<% elsif current_user && !current_user.role %>
  <div class="container py-5">
    <div class="row g-4 mb-4">
      <div class="col-md-8">
        Your subscription to <%= current_user.family.name %> is waiting for validation.
      </div>
    </div>
  </div>
<% else %>
  <!-- HERO / BANNER -->
  <div class="banner">
    <div class="banner-content text-center">
      <h1>Bring harmony to your family life</h1>
      <p>Meals, tasks, and rewards — all organized in one place</p>
      <div class="d-flex flex-wrap justify-content-center gap-2">
        <%= link_to "Get Started", new_user_registration_path, class: "btn btn-primary btn-lg fs-6" %>
        <%= link_to "Log in", new_user_session_path, class: "btn btn-info btn-lg fs-6" %>
      </div>
    </div>
  </div>
<% end %>
