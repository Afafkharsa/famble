<%# Subscribe to action cable %>
<%= turbo_stream_from @chat %>

<div class="chat-page">
  <div class="container py-4 pb-5" style="max-width: 860px;">

    <div class="d-flex align-items-end justify-content-between flex-wrap gap-3 mb-3">
      <div>
        <h1 class="h3 fw-bold mb-1" id="chat_title">
          <%= @chat.title == "Untitled" ? "Famble AI" : @chat.title %>
        </h1>
        <p class="text-muted small mb-0">Ask about meals, tasks, rewards, or the calendar</p>
      </div>
      <%= link_to chats_path, class: "btn btn-outline-dark" do %>
        <i class="bi bi-list-ul me-1"></i> All chats
      <% end %>
    </div>

    <div class="card rounded-5 border-0 shadow-sm overflow-hidden" style="background: #fff;">
      <div id="messages" class="p-4" style="min-height: 420px; background: #fff;">
        <%= render "messages/messages", messages: @chat.messages %>
      </div>
      <div class="border-top p-3" id="new_message_container" style="background: #fff;">
        <%= render "messages/form", chat: @chat, message: @message %>
      </div>
    </div>

  </div>
</div>
