<div class="container py-4">
  <h1 class="text-shadow">My Chats</h1>

  <div class="d-flex justify-content-between">
    <div class="card mt-4 border-0 list-group col-md-7 bg-transparent">
      <% if @chats.any? %>
        <% @chats.each do |chat| %>
          <div class="list-group-item d-flex justify-content-between align-items-center">
            <%= link_to chat.title, chat_path(chat),
            class: "text-decoration-none text-dark flex-grow-1" %>

            <%= button_to chat_path(chat),
                method: :delete,
                data: { turbo_confirm: "Delete this chat?" },
                class: "btn text-muted ms-2" do %>
              <i class="bi bi-trash"></i>
            <% end %>

          </div>
        <% end %>
      <% else %>
        <p>No chats yet.</p>
      <% end %>
    </div>

    <div class="col-md-4 mt-4 text-center">
      <%= render "shared/ai_card" %>
    </div>
  </div>
</div>
