<div class="container py-4">
  <h1 class="mb-4">My Chats</h1>

  <div class="d-flex justify-content-between align-items-start">
    <div class="col-md-7">
      <% if @chats.any? %>
        <div class="d-flex flex-column gap-2 mt-2">
          <% @chats.each do |chat| %>
            <div class="d-flex justify-content-between align-items-center p-3 bg-white rounded-2 shadow-sm">

              <%= link_to chat_path(chat), class: "text-decoration-none text-dark flex-grow-1" do %>
                <div>
                  <%= chat.title %>
                </div>
              <% end %>

              <%= button_to chat_path(chat),
                  method: :delete,
                  data: { turbo_confirm: "Delete this chat?" },
                  class: "btn btn-sm text-muted ms-3" do %>
                <i class="bi bi-trash"></i>
              <% end %>

            </div>
          <% end %>
        </div>
      <% else %>
        <div class="mt-4 text-muted">
          <p>No chats yet.</p>
        </div>
      <% end %>
    </div>

    <div class="col-md-4 mt-2 text-center">
      <%= render "shared/ai_card" %>
    </div>
  </div>
</div>
