<div class="container py-4">
  <h1 class="mb-4">My Chats</h1>

  <div class="d-flex justify-content-between align-items-start">
    <div class="col-md-7">
      <% if @chats.any? %>
        <div class="bg-white border rounded-3 mt-2 overflow-hidden">
          <% @chats.each do |chat| %>
            <div
              class="d-flex justify-content-between align-items-center p-3 chat-row"
              data-controller="clickable"
              data-clickable-url-value="<%= chat_path(chat) %>"
              data-action="click->clickable#go"
            >

              <div class="flex-grow-1">
                <%= link_to chat.title, chat_path(chat), class: "text-decoration-none" %>
              </div>

              <%= button_to chat_path(chat),
                  method: :delete,
                  data: { turbo_confirm: "Delete this chat?" },
                  class: "btn btn-sm text-muted ms-3" do %>
                <i class="bi bi-trash"></i>
              <% end %>

            </div>
          <% end %>
        </div>
      <% else %>
        <div class="mt-4 text-muted">
          <p>No chats yet.</p>
        </div>
      <% end %>
    </div>

    <div class="col-md-4 mt-2 text-center">
      <%= render "shared/ai_card" %>
    </div>
  </div>
</div>
