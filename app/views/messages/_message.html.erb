<% loading_messages = [
  "Cooking something delicious...",
  "Stirring the ingredients together...",
  "Simmering something tasty...",
  "Adding a pinch of magic...",
] %>

<% if message.role == "user" %>
  <% user = message.chat.user %>
  <% user_initials = (user.name || user.email).split(' ').map { |w| w[0].upcase }.first(2).join %>
  <div class="msg msg-user">
    <div class="msg-avatar msg-avatar-user" style="background: <%= user.avatar_color %>; overflow: hidden; position: relative;">
      <span style="font-size:10px;font-weight:700;color:rgba(14,0,0,0.5);">
        <%= user_initials %>
      </span>
      <% if user.photo.attached? %>
        <%= image_tag user.photo,
            style: "width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0;",
            onerror: "this.style.display='none'" %>
      <% end %>
    </div>
    <div class="msg-bubble msg-bubble-user">
      <%= message.content %>
    </div>
  </div>

<% elsif message.role == "assistant" %>
  <div class="msg msg-ai" id="<%= dom_id(message) %>">
    <div class="msg-avatar msg-avatar-ai">
      <i class="bi bi-stars" style="font-size:11px;color:white;"></i>
    </div>
    <div class="msg-bubble msg-bubble-ai">

      <% if message.content.present? %>
        <% begin %>
          <% json_str = message.content.match(/\{.*\}/m)&.to_s || message.content %>
          <% recipe = JSON.parse(json_str) %>
          <% raise JSON::ParserError unless recipe.is_a?(Hash) && recipe["name"].present? %>

          <h5 class="text-success"><%= recipe["name"] %></h5>
          <p>
            <% Array(recipe["keywords"]).each do |keyword| %>
              <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-2 me-1">
                <%= keyword.strip %>
              </span>
            <% end %>
          </p>
          <p class="text-muted mb-1" style="font-size: 0.85rem;">
            <i class="fas fa-fire me-1"></i> <%= recipe["calories"] %> kcal &nbsp;|&nbsp;
            <i class="fas fa-exclamation-triangle me-1"></i>
            <%= Array(recipe["allergens"]).join(", ").presence || "No allergens" %>
          </p>
          <details class="mb-2">
            <summary class="text-primary" style="cursor:pointer;"><strong>Ingredients</strong></summary>
            <ul class="mt-2">
              <% Array(recipe["ingredients"]).each do |item| %>
                <li><%= item["ingredient"] %> — <%= item["quantity"] %></li>
              <% end %>
            </ul>
          </details>
          <details class="mb-3">
            <summary class="text-primary" style="cursor:pointer;"><strong>Description</strong></summary>
            <ol class="mt-2">
              <% Array(recipe["description"]).each do |step| %>
                <li><%= step %></li>
              <% end %>
            </ol>
          </details>

          <%= form_with url: recipes_path, method: :post do |f| %>
            <div class="row g-2">
              <div class="col-6">
                <%= date_field_tag "recipe[meal_plan_date]", Date.today, class: "form-control form-control-sm rounded-pill" %>
              </div>
              <div class="col-6">
                <%= select_tag "recipe[meal_plan_type]",
                  options_for_select(["Breakfast", "Lunch", "Dinner"]),
                  class: "form-select form-select-sm rounded-pill" %>
              </div>
            </div>
            <div class="mt-2">
              <%= text_field_tag "recipe[photo]", nil,
                class: "form-control form-control-sm rounded-pill",
                placeholder: "Paste an image URL (optional)..." %>
            </div>
            <%= hidden_field_tag "recipe[name]", recipe["name"] %>
            <%= hidden_field_tag "recipe[ingredients]", Array(recipe["ingredients"]).map { |i| "#{i['ingredient']} - #{i['quantity']}" }.join("\n") %>
            <%= hidden_field_tag "recipe[description]", Array(recipe["description"]).join("\n") %>
            <%= hidden_field_tag "recipe[keywords]", Array(recipe["keywords"]).join(", ") %>
            <%= hidden_field_tag "recipe[calories]", recipe["calories"] %>
            <%= hidden_field_tag "recipe[allergens]", Array(recipe["allergens"]).join(", ") %>
            <div class="row g-2 mt-1">
              <div class="col-6">
                <%= submit_tag "Add to Meal Plan", name: "save_to_meal_plan", class: "btn btn-warning btn-sm w-100 rounded-pill" %>
              </div>
              <div class="col-6">
                <%= button_tag type: "submit", name: "save_recipe", class: "btn btn-outline-warning btn-sm w-100 rounded-pill" do %>
                  <i class="fa-regular fa-floppy-disk"></i> Save
                <% end %>
              </div>
            </div>
          <% end %>

        <% rescue JSON::ParserError %>
          <% if message.content.strip.start_with?('{') %>
            <div class="text-muted fst-italic d-flex align-items-center gap-2">
              <div class="spinner-border spinner-border-sm" role="status"></div>
              <%= loading_messages.sample %>
            </div>
          <% else %>
            <%= simple_format(message.content) %>
          <% end %>
        <% end %>

      <% else %>
        ...
      <% end %>

    </div>
  </div>
<% end %>
