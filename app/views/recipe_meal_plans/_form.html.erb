<%# app/views/recipe_meal_plans/_form.html.erb %>
<div class="container mt-4">
  <div class="row justify-content-left ms-2">
    <div class="col-md-12">
      <%= simple_form_for(@recipe_meal_plan) do |f| %>

        <%# Edit date calling from meal_plan %>
        <%= f.simple_fields_for :meal_plan do |mp| %>
          <div class="form-inputs fw-bold">
            <%= mp.input :day, as: :date, html5: true, label: "Select Date" %>
          </div>
        <% end %>

        <%# Change meal type & meal %>
        <div class="form-inputs fw-bold">
          <%= f.input :meal_type, collection: ["Breakfast", "Lunch", "Dinner", "Snack"], prompt: "Select meal type" %>
          <%= f.association :recipe, label: "Choose Recipe", prompt: "Select a recipe" %>

          <%# Upload photo %>
          <%= f.input :photo, as: :file, label: "Photo" if f.object.respond_to?(:photo) %>
        </div>

        <div class="d-flex gap-3 mb-4 mt-2">
          <%= f.submit class: "btn btn-secondary rounded-4 fs-5" %>
          <%= link_to "Cancel", meal_plans_path, class: "btn btn-outline-secondary rounded-4 fs-5" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
